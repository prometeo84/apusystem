# ENV Variables for APU System

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=CHANGE_ME_TO_RANDOM_SECRET_KEY_32_CHARS
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://root:root@mysql:3306/apu_system?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/mailer ###
MAILER_DSN=smtp://mailpit:1025
###< symfony/mailer ###

###> Security ###
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_JWT_SECRET_KEY
TRUSTED_DEVICE_COOKIE_NAME=trusted_device_token
TRUSTED_DEVICE_EXPIRY_DAYS=30
SESSION_LIFETIME=7200
# API key used by cron-job.org webhooks; change to a secure random value
CRON_JOB_API_KEY=changeme_replace_with_secure_key
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
###< Security ###

###> Rate Limiting ###
RATE_LIMIT_LOGIN=5
RATE_LIMIT_API=100
RATE_LIMIT_ADMIN_ACTIONS=10
###< Rate Limiting ###

###> 2FA Settings ###
APP_NAME="APU System"
TOTP_ISSUER="APU System"
RECOVERY_CODES_COUNT=10
###< 2FA Settings ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> symfony/lock ###
# Choose one of the stores below
# postgresql+advisory://db_user:db_password@localhost/db_name
LOCK_DSN=flock
###< symfony/lock ###
