# Seguridad para archivos Revit subidos
# Solo permitir descarga de archivos IFC, JSON, RVT
# Bloquear ejecución de scripts

<IfModule mod_authz_core.c>
    # Denegar acceso por defecto
    <FilesMatch ".*">
        Require all denied
    </FilesMatch>

    # Permitir solo archivos Revit
    <FilesMatch "\.(ifc|json|rvt)$">
        Require all granted
    </FilesMatch>
</IfModule>

# Soporte Apache 2.2
<IfModule !mod_authz_core.c>
    Order Deny,Allow
    Deny from all
    <FilesMatch "\.(ifc|json|rvt)$">
        Allow from all
    </FilesMatch>
</IfModule>

# Bloquear ejecución de PHP
<FilesMatch "\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>

# Deshabilitar listado de directorios
Options -Indexes

# Forzar descarga de archivos en lugar de ejecución
<IfModule mod_headers.c>
    <FilesMatch "\.(ifc|json|rvt)$">
        Header set Content-Disposition "attachment"
    </FilesMatch>
</IfModule>

# Tipos MIME correctos
<IfModule mod_mime.c>
    AddType application/json .json
    AddType text/plain .ifc
    AddType application/octet-stream .rvt
</IfModule>
