#!/usr/bin/env bash
# =============================================================
#  Pre-commit hook – APU System
#  Fuente versionada: .githooks/pre-commit
#
#  BLOQUEANTES (exit 1 – nunca modifican archivos):
#    1. PHP syntax     – php -l                (staged .php)
#    2. Python syntax  – python3 -m py_compile (staged .py)
#    3. actionlint     – workflows staged      (staged .yml/.yaml en .github/)
#
#  NO BLOQUEANTES (advertencias, commit continúa):
#    4. OWASP Top 10   – grep de patrones      (todos los staged)
#
#  Linters pesados (PHPStan, PHPCS, Snyk, ESLint, Stylelint,
#  Composer audit) → scripts/run-heavy-linters.sh (pre-push)
# =============================================================
set -uo pipefail
IFS=$'\n\t'

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

GIT_ROOT=$(git rev-parse --show-toplevel)
cd "$GIT_ROOT"

STAGED_PHP=$(git  diff --cached --name-only --diff-filter=ACM | grep -E '\.php$'  || true)
STAGED_PY=$(git   diff --cached --name-only --diff-filter=ACM | grep -E '\.py$'   || true)
STAGED_WF=$(git   diff --cached --name-only --diff-filter=ACM | grep -E '^\.github/workflows/.*\.ya?ml$' || true)
STAGED_ALL=$(git  diff --cached --name-only --diff-filter=ACM || true)
# Solo archivos de aplicación – excluye hooks/scripts/vendor para evitar falsos positivos OWASP
STAGED_APP=$(echo "$STAGED_ALL" | grep -vE '^(\.githooks/|scripts/|\.tools/|vendor/|node_modules/)' || true)

BLOCKING_ERRORS=0

echo ""
echo -e "${BOLD}============================================================${NC}"
echo -e "${BOLD}  Pre-commit hook – APU System${NC}"
echo -e "${BOLD}  (linters pesados corren al hacer push)${NC}"
echo -e "${BOLD}============================================================${NC}"

# =============================================================
#  BLOQUE 1: BLOQUEANTES
# =============================================================
echo ""
echo -e "${BOLD}-- VALIDACIONES BLOQUEANTES --------------------------------${NC}"

# -- 1. PHP Syntax -------------------------------------------
echo ""
echo -e "${CYAN}[1/3] PHP Syntax (php -l)${NC}"
if [ -n "$STAGED_PHP" ]; then
    PHP_OK=0; PHP_FAIL=0
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        ABS="$GIT_ROOT/$file"
        [ -f "$ABS" ] || continue
        result=$(php -l "$ABS" 2>&1)
        rc=$?
        if [ "$rc" -ne 0 ]; then
            echo -e "${RED}  x ERROR: $file${NC}"
            echo "$result" | sed 's/^/      /'
            PHP_FAIL=$((PHP_FAIL+1))
            BLOCKING_ERRORS=$((BLOCKING_ERRORS+1))
        else
            echo -e "${GREEN}  ok $file${NC}"
            PHP_OK=$((PHP_OK+1))
        fi
    done <<< "$STAGED_PHP"
    echo "    Resultado: ${PHP_OK} OK  |  ${PHP_FAIL} ERROR(ES)"
else
    echo "  Sin archivos .php staged"
fi

# -- 2. Python Syntax ----------------------------------------
echo ""
echo -e "${CYAN}[2/3] Python Syntax (python3 -m py_compile)${NC}"
if [ -n "$STAGED_PY" ]; then
    PY_OK=0; PY_FAIL=0
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        ABS="$GIT_ROOT/$file"
        [ -f "$ABS" ] || continue
        result=$(python3 -m py_compile "$ABS" 2>&1)
        rc=$?
        if [ "$rc" -ne 0 ]; then
            echo -e "${RED}  x ERROR: $file${NC}"
            echo "$result" | sed 's/^/      /'
            PY_FAIL=$((PY_FAIL+1))
            BLOCKING_ERRORS=$((BLOCKING_ERRORS+1))
        else
            echo -e "${GREEN}  ok $file${NC}"
            PY_OK=$((PY_OK+1))
        fi
    done <<< "$STAGED_PY"
    echo "    Resultado: ${PY_OK} OK  |  ${PY_FAIL} ERROR(ES)"
else
    echo "  Sin archivos .py staged"
fi

# -- 3. actionlint (workflows staged) -------------------------
echo ""
echo -e "${CYAN}[3/3] actionlint – GitHub workflows${NC}"
if [ -n "$STAGED_WF" ]; then
    ACTIONLINT="$GIT_ROOT/.tools/actionlint"
    if [ ! -x "$ACTIONLINT" ]; then
        ACTIONLINT=$(command -v actionlint 2>/dev/null || true)
    fi
    if [ -n "$ACTIONLINT" ] && [ -x "$ACTIONLINT" ]; then
        WF_FILES=()
        while IFS= read -r f; do
            [ -n "$f" ] && [ -f "$GIT_ROOT/$f" ] && WF_FILES+=("$GIT_ROOT/$f")
        done <<< "$STAGED_WF"
        if [ "${#WF_FILES[@]}" -gt 0 ]; then
            result=$("$ACTIONLINT" "${WF_FILES[@]}" 2>&1) || AL_EXIT=$?
            AL_EXIT=${AL_EXIT:-0}
            if [ "$AL_EXIT" -ne 0 ]; then
                echo -e "${RED}  x actionlint encontró errores en workflows:${NC}"
                echo "$result" | sed 's/^/      /'
                BLOCKING_ERRORS=$((BLOCKING_ERRORS+1))
            else
                echo -e "${GREEN}  ok Workflows válidos${NC}"
            fi
        fi
    else
        echo -e "${YELLOW}  actionlint no disponible – omitido (scripts/install_actionlint.sh)${NC}"
    fi
else
    echo "  Sin workflows staged"
fi

# -- Abortar si hay errores bloqueantes -----------------------
if [ "$BLOCKING_ERRORS" -gt 0 ]; then
    echo ""
    echo -e "${RED}============================================================${NC}"
    echo -e "${RED}  COMMIT ABORTADO – ${BLOCKING_ERRORS} error(es) bloqueante(s)${NC}"
    echo -e "${RED}  Los archivos NO han sido modificados.${NC}"
    echo -e "${RED}  Corrige los errores e intenta el commit de nuevo.${NC}"
    echo -e "${RED}============================================================${NC}"
    exit 1
fi

# =============================================================
#  BLOQUE 2: OWASP Top 10 – patrones (no bloqueante)
# =============================================================
echo ""
echo -e "${BOLD}-- OWASP Top 10 (grep rápido) -------------------------------${NC}"
echo ""
OWASP_TOTAL=0
if [ -n "$STAGED_APP" ]; then
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        ABS="$GIT_ROOT/$file"
        [ -f "$ABS" ] || continue

        # A03 – SQLi: concatenación en queries
        A03=$(grep -nP '(\$[a-zA-Z_]\w*\s*\.\s*["'"'"']|["'"'"']\s*\.\s*\$[a-zA-Z_]\w*)' "$ABS" 2>/dev/null \
            | grep -iE '(query|execute|SELECT|INSERT|UPDATE|DELETE|FROM|WHERE)' \
            | grep -vE '^\s*(//|#|\*)' || true)
        [ -n "$A03" ] && echo -e "${YELLOW}  !! [A03-SQLi]   $file${NC}" && echo "$A03" | head -5 | sed 's/^/      /' && OWASP_TOTAL=$((OWASP_TOTAL+1))

        # A03 – eval
        A03E=$(grep -nE '\beval\s*\(' "$ABS" 2>/dev/null | grep -vE '^\s*(//|#|\*)' || true)
        [ -n "$A03E" ] && echo -e "${YELLOW}  !! [A03-eval]   $file${NC}" && echo "$A03E" | head -3 | sed 's/^/      /' && OWASP_TOTAL=$((OWASP_TOTAL+1))

        # A05 – misconfig: error_reporting all
        A05=$(grep -nEi 'error_reporting\s*\(\s*-1\s*\)|error_reporting\s*\(\s*E_ALL\s*\)' "$ABS" 2>/dev/null \
            | grep -vE '^\s*(//|#|\*)' || true)
        [ -n "$A05" ] && echo -e "${YELLOW}  !! [A05-ErrRep]  $file${NC}" && echo "$A05" | head -3 | sed 's/^/      /' && OWASP_TOTAL=$((OWASP_TOTAL+1))

        # A07 – hashes débiles en passwords
        A07=$(grep -nEi '\b(md5|sha1)\s*\(\s*\$?(password|pass|pwd)' "$ABS" 2>/dev/null \
            | grep -vE '^\s*(//|#|\*)' || true)
        [ -n "$A07" ] && echo -e "${YELLOW}  !! [A07-Auth]   $file${NC}" && echo "$A07" | head -3 | sed 's/^/      /' && OWASP_TOTAL=$((OWASP_TOTAL+1))

        # A07 – CSRF desactivado
        A07C=$(grep -nEi '(csrf_protection:\s*false|enableCsrfProtection\s*\(\s*false)' "$ABS" 2>/dev/null \
            | grep -vE '^\s*(//|#|\*)' || true)
        [ -n "$A07C" ] && echo -e "${YELLOW}  !! [A07-CSRF]   $file${NC}" && echo "$A07C" | head -3 | sed 's/^/      /' && OWASP_TOTAL=$((OWASP_TOTAL+1))

        # A10 – SSRF
        A10=$(grep -nEi '(curl_setopt.*CURLOPT_URL.*\$|file_get_contents\s*\(\s*\$|HttpClient.*get\s*\(\s*\$)' "$ABS" 2>/dev/null \
            | grep -vE '^\s*(//|#|\*)' || true)
        [ -n "$A10" ] && echo -e "${YELLOW}  !! [A10-SSRF]   $file${NC}" && echo "$A10" | head -3 | sed 's/^/      /' && OWASP_TOTAL=$((OWASP_TOTAL+1))

    done <<< "$STAGED_APP"

    if [ "$OWASP_TOTAL" -eq 0 ]; then
        echo -e "${GREEN}  ok Sin patrones OWASP detectados${NC}"
    else
        echo -e "${YELLOW}  !! ${OWASP_TOTAL} patrón(es) OWASP – advertencias (commit continúa)${NC}"
    fi
else
    echo "  Sin archivos staged"
fi

# =============================================================
#  RESUMEN FINAL
# =============================================================
echo ""
echo -e "${GREEN}  COMMIT PERMITIDO${NC}"
echo -e "  Los linters pesados correrán al hacer ${BOLD}git push${NC}"
echo ""
exit 0
