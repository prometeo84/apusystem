#!/usr/bin/env bash
# Pre-commit hook: check PHP syntax for staged PHP files
set -euo pipefail

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E "\.php$" || true)
if [ -z "$STAGED" ]; then
  exit 0
fi

HAS_ERROR=0
for file in $STAGED; do
  # If file was deleted or not present in worktree, skip
  if [ ! -f "$file" ]; then
    continue
  fi
  php -l "$file" >/dev/null 2>&1 || {
    echo "PHP syntax error in staged file: $file"
    php -l "$file"
    HAS_ERROR=1
  }
done

if [ "$HAS_ERROR" -ne 0 ]; then
  echo "Commit aborted due to PHP syntax errors. Fix them before committing." >&2
  exit 1
fi

exit 0
#!/bin/sh
# Simple pre-commit hook: check PHP syntax and Twig syntax for staged files.
STAGED=$(git diff --cached --name-only --diff-filter=ACM)
if [ -z "$STAGED" ]; then
  exit 0
fi
ERR=0
for file in $STAGED; do
  case "$file" in
    *.php)
      docker exec apache php -l "$file" >/dev/null 2>&1
      if [ $? -ne 0 ]; then
        echo "PHP syntax error in $file"
        docker exec apache php -l "$file"
        ERR=1
      fi
      ;;
    *.twig)
      docker exec apache php bin/console lint:twig "$file" >/dev/null 2>&1
      if [ $? -ne 0 ]; then
        echo "Twig syntax error in $file"
        docker exec apache php bin/console lint:twig "$file"
        ERR=1
      fi
      ;;
  esac
done

if [ "$ERR" -ne 0 ]; then
  echo "Commit aborted due to syntax errors. Fix them and try again."
  exit 1
fi

exit 0
#!/usr/bin/env bash
# ═══════════════════════════════════════════════════════════════
#  Pre-commit hook — APU System
#  Versión versionada : .githooks/pre-commit
#  Versión activa     : .git/hooks/pre-commit
#
#  BLOQUEANTES (exit 1, NUNCA modifican archivos fuente):
#    1. PHP syntax   — php -l
#    2. Python syntax — python3 -m py_compile
#
#  NO BLOQUEANTES (advertencias, commit sigue):
#    3. PHPCS         — phpcs.xml (staged)
#    4. Psalm         — nivel 4 (proyecto completo)
#    5. PHPStan       — nivel 5 (staged en src/)
#    6. ESLint        — assets/
#    7. Stylelint     — assets/
#    8. OWASP Top 10:2026 — patrones de seguridad (staged)
#    9. Snyk          — solo si instalado y autenticado
# ═════════════════════════════════════════════════════════════
#  BLOQUE 3: OWASP Top 10:2026 — detección de patrones
# ═════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}── OWASP Top 10:2026 — Detección de patrones (staged) ───────${NC}"
echo ""

# ── Semgrep (OWASP Top 10:2026 rules) — no bloqueante pero informativo
SEMGREP_BIN=$(command -v semgrep 2>/dev/null || true)
if [ -n "$SEMGREP_BIN" ]; then
    echo ""
    echo -e "${YELLOW}  Ejecutando semgrep (OWASP Top 10:2026)...${NC}"
    # Intentar reglas públicas; si no están disponibles, semgrep fallará con rc!=0
    SEMGREP_CONF_REMOTE="https://semgrep.dev/p/owasp-top-10"
    SEMGREP_OUTPUT=$("$SEMGREP_BIN" --config="$SEMGREP_CONF_REMOTE" --exclude vendor --quiet "$GIT_ROOT" 2>&1)
    SEMGREP_RC=$?
    if [ $SEMGREP_RC -eq 0 ]; then
        echo -e "${GREEN}  ✓ semgrep: no se detectaron issues relevantes (owasp top-10)${NC}"
    else
        echo -e "${YELLOW}  ⚠  semgrep reportó posibles issues (OWASP Top 10:2026). Revise la salida:${NC}"
        echo "$SEMGREP_OUTPUT" | sed 's/^/      /'
        echo ""
    fi
else
    echo "  ℹ  semgrep no instalado — instalar con 'pip install semgrep' o 'pipx install semgrep'"
fi

OWASP_TOTAL=0
# contador de errores bloqueantes (inicializar para evitar comparación con vacío)
BLOCKING_ERRORS=0
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# ── Archivos staged ────────────────────────────────────────────
STAGED_PHP=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.php$' || true)
STAGED_PY=$(git diff --cached --name-only  --diff-filter=ACM | grep -E '\.py$'  || true)
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM || true)
STAGED_JS=$(git diff  --cached --name-only --diff-filter=ACM | grep -E '\.js$'  | grep '^assets/' || true)
STAGED_CSS=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(css|scss|sass)$' | grep '^assets/' || true)

echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════════════${NC}"
echo -e "${BOLD}  🔒 Pre-commit hook — APU System${NC}"
echo -e "${BOLD}═══════════════════════════════════════════════════════════${NC}"

# ══════════════════════════════════════════════════════════════
#  BLOQUE 1: BLOQUEANTES
# ══════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}── VALIDACIONES BLOQUEANTES ─────────────────────────────────${NC}"

# ── 1. PHP Syntax ─────────────────────────────────────────────
echo ""
echo -e "${CYAN}[1/2] PHP Syntax (php -l)${NC}"

if [ -n "$STAGED_PHP" ]; then
    PHP_OK=0
    PHP_FAIL=0
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        ABS_FILE="$GIT_ROOT/$file"
        [ -f "$ABS_FILE" ] || continue
        result=$(php -l "$ABS_FILE" 2>&1)
        rc=$?
        if [ $rc -ne 0 ]; then
            echo -e "${RED}  ✗ ERROR SINTAXIS: $file${NC}"
            echo "$result" | sed 's/^/      /'
            PHP_FAIL=$((PHP_FAIL + 1))
            BLOCKING_ERRORS=$((BLOCKING_ERRORS + 1))
        else
            echo -e "${GREEN}  ✓ $file${NC}"
            PHP_OK=$((PHP_OK + 1))
        fi
    done <<< "$STAGED_PHP"
    echo "    Resultado: ${PHP_OK} OK  |  ${PHP_FAIL} ERROR(ES)"
else
    echo "  ℹ  Sin archivos .php staged"
fi

# ── 2. Python Syntax ──────────────────────────────────────────
echo ""
echo -e "${CYAN}[2/2] Python Syntax (python3 -m py_compile)${NC}"

if [ -n "$STAGED_PY" ]; then
    PY_OK=0
    PY_FAIL=0
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        ABS_FILE="$GIT_ROOT/$file"
        [ -f "$ABS_FILE" ] || continue
        result=$(python3 -m py_compile "$ABS_FILE" 2>&1)
        rc=$?
        if [ $rc -ne 0 ]; then
            echo -e "${RED}  ✗ ERROR SINTAXIS: $file${NC}"
            echo "$result" | sed 's/^/      /'
            PY_FAIL=$((PY_FAIL + 1))
            BLOCKING_ERRORS=$((BLOCKING_ERRORS + 1))
        else
            echo -e "${GREEN}  ✓ $file${NC}"
            PY_OK=$((PY_OK + 1))
        fi
    done <<< "$STAGED_PY"
    echo "    Resultado: ${PY_OK} OK  |  ${PY_FAIL} ERROR(ES)"
else
    echo "  ℹ  Sin archivos .py staged"
fi

# ── Abortar si hay errores bloqueantes ────────────────────────
if [ "$BLOCKING_ERRORS" -gt 0 ]; then
    echo ""
    echo -e "${RED}═══════════════════════════════════════════════════════════${NC}"
    echo -e "${RED}  ✗ COMMIT ABORTADO${NC}"
    echo -e "${RED}  Se encontraron ${BLOCKING_ERRORS} error(es) de sintaxis bloqueante(s).${NC}"
    echo -e "${RED}  Los archivos NO han sido modificados ni eliminados.${NC}"
    echo -e "${RED}  Corrija los errores de sintaxis e intente el commit nuevamente.${NC}"
    echo -e "${RED}═══════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${BOLD}Comandos de auto-fix:${NC}"
    echo "  ┌─ PHP ────────────────────────────────────────────────────"
    echo "  │  php -l <archivo>                    # verificar sintaxis"
    echo "  │  vendor/bin/phpcbf <archivo>         # auto-corregir estilo"
    echo "  └──────────────────────────────────────────────────────────"
    echo ""
    exit 1
fi

# ══════════════════════════════════════════════════════════════
#  BLOQUE 2: NO BLOQUEANTES
# ══════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}── VALIDACIONES NO BLOQUEANTES (advertencias) ───────────────${NC}"

# ── 3. PHPCS ──────────────────────────────────────────────────
echo ""
echo -e "${YELLOW}[3/7] PHPCS — estilo de código PHP (staged)${NC}"

if [ -n "$STAGED_PHP" ]; then
    PHPCS_BIN="$GIT_ROOT/vendor/bin/phpcs"
    [ -f "$PHPCS_BIN" ] || PHPCS_BIN=$(command -v phpcs 2>/dev/null || true)

    if [ -n "$PHPCS_BIN" ] && [ -f "$PHPCS_BIN" ]; then
        PHPCS_CFG="$GIT_ROOT/phpcs.xml"
        PHPCS_STD=""
        [ -f "$PHPCS_CFG" ] && PHPCS_STD="--standard=$PHPCS_CFG"

        PHPCS_FILES=()
        while IFS= read -r file; do
            [ -z "$file" ] && continue
            ABS_FILE="$GIT_ROOT/$file"
            [ -f "$ABS_FILE" ] && PHPCS_FILES+=("$ABS_FILE")
        done <<< "$STAGED_PHP"

        if [ ${#PHPCS_FILES[@]} -gt 0 ]; then
            result=$("$PHPCS_BIN" $PHPCS_STD "${PHPCS_FILES[@]}" 2>&1)
            if [ $? -ne 0 ]; then
                echo -e "${YELLOW}  ⚠  PHPCS encontró problemas de estilo:${NC}"
                echo "$result" | sed 's/^/      /'
            else
                echo -e "${GREEN}  ✓ Sin problemas de estilo${NC}"
            fi
        fi
    else
        echo "  ℹ  phpcs no encontrado (vendor/bin/phpcs o PATH) — se omite"
    fi
else
    echo "  ℹ  Sin archivos .php staged"
fi

# ── 4. Psalm nivel 4 (proyecto completo) ──────────────────────
echo ""
echo -e "${YELLOW}[4/7] Psalm nivel 4 (proyecto completo)${NC}"

PSALM_BIN="$GIT_ROOT/vendor/bin/psalm"
[ -f "$PSALM_BIN" ] || PSALM_BIN=$(command -v psalm 2>/dev/null || true)

if [ -n "$PSALM_BIN" ] && [ -f "$PSALM_BIN" ]; then
    result=$("$PSALM_BIN" \
        --root="$GIT_ROOT" \
        --error-level=4 \
        --no-progress \
        --output-format=compact \
        2>&1)
    if [ $? -ne 0 ]; then
        echo -e "${YELLOW}  ⚠  Psalm encontró problemas:${NC}"
        echo "$result" | sed 's/^/      /'
    else
        echo -e "${GREEN}  ✓ Sin errores Psalm (nivel 4)${NC}"
    fi
else
    echo "  ℹ  psalm no instalado — se omite (composer require --dev vimeo/psalm)"
fi

# ── 5. PHPStan nivel 5 (staged en scope src/) ─────────────────
echo ""
echo -e "${YELLOW}[5/7] PHPStan nivel 5 (staged en src/)${NC}"

if [ -n "$STAGED_PHP" ]; then
    PHPSTAN_BIN="$GIT_ROOT/vendor/bin/phpstan"
    [ -f "$PHPSTAN_BIN" ] || PHPSTAN_BIN=$(command -v phpstan 2>/dev/null || true)

    if [ -n "$PHPSTAN_BIN" ] && [ -f "$PHPSTAN_BIN" ]; then
        PHPSTAN_FILES=()
        while IFS= read -r file; do
            [ -z "$file" ] && continue
            # Scope de la app: src/
            [[ "$file" == src/* ]] || continue
            ABS_FILE="$GIT_ROOT/$file"
            [ -f "$ABS_FILE" ] && PHPSTAN_FILES+=("$ABS_FILE")
        done <<< "$STAGED_PHP"

        if [ ${#PHPSTAN_FILES[@]} -gt 0 ]; then
            # Usa la configuración del proyecto si existe
            PHPSTAN_CFG="$GIT_ROOT/phpstan.neon"
            PHPSTAN_CFGARG=""
            [ -f "$PHPSTAN_CFG" ] && PHPSTAN_CFGARG="--configuration=$PHPSTAN_CFG"

            result=$("$PHPSTAN_BIN" analyse \
                #!/bin/sh
                # Pre-commit: comprueba sintaxis PHP y Twig para archivos staged
                # Usa el directorio de trabajo del proyecto dentro del contenedor para resolver rutas.
                STAGED=$(git diff --cached --name-only --diff-filter=ACM)
                if [ -z "$STAGED" ]; then
                    exit 0
                fi

                CONTAINER=apache
                CONTAINER_ROOT=/var/www/html/proyecto
                ERR=0

                for file in $STAGED; do
                    case "$file" in
                        *.php)
                            docker exec -w "$CONTAINER_ROOT" $CONTAINER php -l "$file" >/dev/null 2>&1
                            if [ $? -ne 0 ]; then
                                echo "PHP syntax error in $file"
                                docker exec -w "$CONTAINER_ROOT" $CONTAINER php -l "$file"
                                ERR=1
                            fi
                            ;;
                        *.twig)
                            docker exec -w "$CONTAINER_ROOT" $CONTAINER php bin/console lint:twig "$file" >/dev/null 2>&1
                            if [ $? -ne 0 ]; then
                                echo "Twig syntax error in $file"
                                docker exec -w "$CONTAINER_ROOT" $CONTAINER php bin/console lint:twig "$file"
                                ERR=1
                            fi
                            ;;
                    esac
                done

                if [ "$ERR" -ne 0 ]; then
                    echo "Commit aborted due to syntax errors. Fix them and try again."
                    exit 1
                fi

                exit 0


        if [ ${#ESLINT_FILES[@]} -gt 0 ]; then
            result=$("$ESLINT_BIN" "${ESLINT_FILES[@]}" 2>&1)
            if [ $? -ne 0 ]; then
                echo -e "${YELLOW}  ⚠  ESLint encontró problemas:${NC}"
                echo "$result" | sed 's/^/      /'
            else
                echo -e "${GREEN}  ✓ Sin problemas ESLint${NC}"
            fi
        fi
    else
        echo "  ℹ  eslint no instalado — se omite (npm install --save-dev eslint)"
    fi
else
    echo "  ℹ  Sin archivos .js staged en assets/"
fi

# ── 7. Stylelint (assets/) ────────────────────────────────────
echo ""
echo -e "${YELLOW}[7/7] Stylelint (assets/ — archivos CSS staged)${NC}"

if [ -n "$STAGED_CSS" ]; then
    STYLELINT_BIN="$GIT_ROOT/node_modules/.bin/stylelint"
    [ -f "$STYLELINT_BIN" ] || STYLELINT_BIN=$(command -v stylelint 2>/dev/null || true)

    if [ -n "$STYLELINT_BIN" ] && [ -f "$STYLELINT_BIN" ]; then
        STYLELINT_FILES=()
        while IFS= read -r file; do
            [ -z "$file" ] && continue
            ABS_FILE="$GIT_ROOT/$file"
            [ -f "$ABS_FILE" ] && STYLELINT_FILES+=("$ABS_FILE")
        done <<< "$STAGED_CSS"

        if [ ${#STYLELINT_FILES[@]} -gt 0 ]; then
            result=$("$STYLELINT_BIN" "${STYLELINT_FILES[@]}" 2>&1)
            if [ $? -ne 0 ]; then
                echo -e "${YELLOW}  ⚠  Stylelint encontró problemas:${NC}"
                echo "$result" | sed 's/^/      /'
            else
                echo -e "${GREEN}  ✓ Sin problemas Stylelint${NC}"
            fi
        fi
    else
        echo "  ℹ  stylelint no instalado — se omite (npm install --save-dev stylelint)"
    fi
else
    echo "  ℹ  Sin archivos CSS/SCSS staged en assets/"
fi

# ══════════════════════════════════════════════════════════════
#  BLOQUE 3: OWASP Top 10:2025 — detección de patrones
# ══════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}── OWASP Top 10:2025 — Detección de patrones (staged) ───────${NC}"
echo ""

OWASP_TOTAL=0

if [ -n "$STAGED_ALL" ]; then
    while IFS= read -r file; do
        [ -z "$file" ] && continue
        ABS_FILE="$GIT_ROOT/$file"
        [ -f "$ABS_FILE" ] || continue

        # ── A03: Injection — SQL Injection ────────────────────
        # Detecta concatenación directa de variables en queries SQL
        A03_MATCH=$(grep -nE \
            "(\\\$[a-zA-Z_][a-zA-Z0-9_]*\s*\.\s*[\"']|[\"']\s*\.\s*\\\$[a-zA-Z_][a-zA-Z0-9_]*)" \
            "$ABS_FILE" 2>/dev/null \
            | grep -iE "(query|execute|prepare|SELECT|INSERT|UPDATE|DELETE|FROM|WHERE)" \
            | grep -vE "^\s*(//|#|\*\/|\/\*)" \
            || true)
        if [ -n "$A03_MATCH" ]; then
            echo -e "${YELLOW}  ⚠  [A03-SQLi] $file — posible concatenación en query SQL:${NC}"
            echo "$A03_MATCH" | head -5 | sed 's/^/      /'
            OWASP_TOTAL=$((OWASP_TOTAL + 1))
        fi

        # ── A03: Injection — eval / exec dinámico ─────────────
        A03_EVAL=$(grep -nE "\beval\s*\(" "$ABS_FILE" 2>/dev/null \
            | grep -vE "^\s*(//|#|\*)" || true)
        if [ -n "$A03_EVAL" ]; then
            echo -e "${YELLOW}  ⚠  [A03-Inject] $file — uso de eval():${NC}"
            echo "$A03_EVAL" | head -3 | sed 's/^/      /'
            OWASP_TOTAL=$((OWASP_TOTAL + 1))
        fi

        # ── A02: Cryptographic Failures — secretos hardcoded ──
        A02_MATCH=$(grep -nEi \
            "(password|secret|api_key|token|passwd|private_key)\s*=\s*['\"][^'\"]{6,}['\"]" \
            "$ABS_FILE" 2>/dev/null \
            | grep -vE "^\s*(//|#|\*)" \
            | grep -vE "(\\\$|%|env\(|getenv\(|APP_|symfony|placeholder|example|change_me|your_|<)" \
            || true)
        if [ -n "$A02_MATCH" ]; then
            echo -e "${YELLOW}  ⚠  [A02-Crypto] $file — posible secreto hardcoded:${NC}"
            echo "$A02_MATCH" | head -5 | sed 's/^/      /'
            OWASP_TOTAL=$((OWASP_TOTAL + 1))
        fi

        # ── A07: Auth Failures — hashes débiles para contraseñas
        A07_MATCH=$(grep -nEi \
            "\b(md5|sha1)\s*\(\s*\\\$?(password|pass|pwd|contraseña)" \
            "$ABS_FILE" 2>/dev/null \
            | grep -vE "^\s*(//|#|\*)" || true)
        if [ -n "$A07_MATCH" ]; then
            echo -e "${YELLOW}  ⚠  [A07-Auth] $file — hash débil (md5/sha1) en dato de autenticación:${NC}"
            echo "$A07_MATCH" | head -3 | sed 's/^/      /'
            OWASP_TOTAL=$((OWASP_TOTAL + 1))
        fi

        # ── A07: Auth — disable_csrf / CSRF ignorado ──────────
        A07_CSRF=$(grep -nEi \
            "(csrf_protection:\s*false|enableCsrfProtection\s*\(\s*false|@DisableCsrfProtection)" \
            "$ABS_FILE" 2>/dev/null \
            | grep -vE "^\s*(//|#|\*)" || true)
        if [ -n "$A07_CSRF" ]; then
            echo -e "${YELLOW}  ⚠  [A07-Auth] $file — CSRF explícitamente desactivado:${NC}"
            echo "$A07_CSRF" | head -3 | sed 's/^/      /'
            OWASP_TOTAL=$((OWASP_TOTAL + 1))
        fi

        # ── A09: Security Logging Failures — catch vacío ──────
        # Detecta bloques catch{} que no contienen ninguna llamada a log/logger/throw
        while IFS= read -r catch_line; do
            [ -z "$catch_line" ] && continue
            LINENO=$(echo "$catch_line" | cut -d: -f1)
            # Leer hasta 6 líneas después del catch para ver su cuerpo
            BODY=$(sed -n "$((LINENO+1)),$((LINENO+6))p" "$ABS_FILE" 2>/dev/null || true)
            if ! echo "$BODY" | grep -qiE "(log|logger|throw|rethrow|error|warning|critical|monolog|syslog|exception)"; then
                # Si el cuerpo termina con } es un catch vacío o silencioso
                if echo "$BODY" | grep -qE "^\s*\}"; then
                    echo -e "${YELLOW}  ⚠  [A09-Logging] $file:$LINENO — catch aparentemente silencioso (sin log/throw):${NC}"
                    echo "$catch_line" | sed 's/^/      /'
                    OWASP_TOTAL=$((OWASP_TOTAL + 1))
                    break
                fi
            fi
        done <<< "$(grep -nE "^\s*}\s*catch\s*\(|^\s*catch\s*\(" "$ABS_FILE" 2>/dev/null | head -10 || true)"

        # ── A01: Broken Access Control — is_admin / role check hardcoded
        A01_MATCH=$(grep -nEi \
            "(is_admin\(\)|if\s*\(\s*\\\$user\s*==\s*(null|false)|ROLE_SUPER_ADMIN.*hardcoded)" \
            "$ABS_FILE" 2>/dev/null \
            | grep -vE "^\s*(//|#|\*)" || true)
        if [ -n "$A01_MATCH" ]; then
            echo -e "${YELLOW}  ⚠  [A01-AccessCtrl] $file — posible control de acceso no robusto:${NC}"
            echo "$A01_MATCH" | head -3 | sed 's/^/      /'
            OWASP_TOTAL=$((OWASP_TOTAL + 1))
        fi

        # ── A05: Security Misconfiguration — debug en producción
        A05_MATCH=$(grep -nEi \
            "(APP_ENV\s*=\s*dev|APP_DEBUG\s*=\s*true|display_errors\s*=\s*on|debug:\s*true)" \
            "$ABS_FILE" 2>/dev/null \
            | grep -vE "^\s*(//|#|\*)" \
            | grep -vE "\.env\.test|\.env\.dev|# example" || true)
        if [ -n "$A05_MATCH" ]; then
            echo -e "${YELLOW}  ⚠  [A05-Misconfig] $file — configuración de debug que podría llegar a producción:${NC}"
            echo "$A05_MATCH" | head -3 | sed 's/^/      /'
            OWASP_TOTAL=$((OWASP_TOTAL + 1))
        fi

        # ── A10: SSRF — curl/HTTP a URL controlada por usuario ─
        A10_MATCH=$(grep -nEi \
            "(curl_setopt.*CURLOPT_URL.*\\\$|file_get_contents\s*\(\s*\\\$|HttpClient.*get\s*\(\s*\\\$)" \
            "$ABS_FILE" 2>/dev/null \
            | grep -vE "^\s*(//|#|\*)" || true)
        if [ -n "$A10_MATCH" ]; then
            echo -e "${YELLOW}  ⚠  [A10-SSRF] $file — petición HTTP con URL derivada de variable (posible SSRF):${NC}"
            echo "$A10_MATCH" | head -3 | sed 's/^/      /'
            OWASP_TOTAL=$((OWASP_TOTAL + 1))
        fi

    done <<< "$STAGED_ALL"

    if [ "$OWASP_TOTAL" -eq 0 ]; then
        echo -e "${GREEN}  ✓ Sin patrones OWASP detectados en archivos staged${NC}"
    else
        echo ""
        echo -e "${YELLOW}  ⚠  Total patrones OWASP detectados: ${OWASP_TOTAL}${NC}"
        echo "     (son advertencias — el commit continúa, pero revisa cada caso)"
    fi
else
    echo "  ℹ  Sin archivos staged"
fi

# ══════════════════════════════════════════════════════════════
#  BLOQUE 4: Snyk
# ══════════════════════════════════════════════════════════════
echo ""
echo -e "${BOLD}── Snyk — análisis de dependencias ──────────────────────────${NC}"
echo ""

SNYK_BIN=$(command -v snyk 2>/dev/null || true)
if [ -n "$SNYK_BIN" ]; then
    # Verificar autenticación (snyk config get api devuelve el token o vacío)
    SNYK_TOKEN=$(snyk config get api 2>/dev/null | grep -v '^undefined$' | grep -v '^$' || true)
    if [ -n "$SNYK_TOKEN" ]; then
        echo -e "${YELLOW}  Ejecutando Snyk test...${NC}"
        result=$(snyk test "$GIT_ROOT" --severity-threshold=high 2>&1)
        if [ $? -ne 0 ]; then
            echo -e "${YELLOW}  ⚠  Snyk encontró vulnerabilidades HIGH/CRITICAL:${NC}"
            echo "$result" | head -40 | sed 's/^/      /'
        else
            echo -e "${GREEN}  ✓ Snyk: sin vulnerabilidades HIGH/CRITICAL${NC}"
        fi
    else
