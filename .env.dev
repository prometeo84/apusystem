# Development environment variables (local). DO NOT COMMIT SECRETS FOR PRODUCTION.
# Copy `.env.dist` to create this file and adapt values as needed.

APP_ENV=dev
APP_DEBUG=1
# Generate a strong secret for local dev (rotate in production)
APP_SECRET=f3b9d2a8c7e6f15b0d4a9c3e7b8f6a12f0e9d8c7a6b5c4d3e2f1a0b9c8d7e6

# Optional: Symfony secrets vault
SYMFONY_DECRYPTION_SECRET=

# Database (local Docker / native dev)
DATABASE_URL=mysql://root:root@127.0.0.1:3306/apu_system

# Mailer (Mailpit / MailHog / local SMTP)
MAILER_DSN=smtp://localhost:1025
MAILER_FROM_ADDRESS=noreply@apusystem.local
MAILER_FROM_NAME="APU System (dev)"

# App / Router
DEFAULT_URI=http://localhost:8000
SESSION_LIFETIME=3600
LOCK_DSN=flock

# JWT (if used locally)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=

# Misc / dev
CRON_JOB_API_KEY=
VAR_DUMPER_SERVER=127.0.0.1:9912
