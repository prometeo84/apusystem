{% extends 'base.html.twig' %}

{% block title %}{{ 'webauthn.title'|trans }}{% endblock %}

{% block body %}
{% import 'partials/_button.html.twig' as btn %}
  <div class="container py-4">
    <h1>{{ 'webauthn.header'|trans }}</h1>

    <div id="creds">
      <ul>
        {% for c in credentials %}
          <li>
            {{ c.createdAt|date('Y-m-d H:i') }} — fmt: {{ c.fmt ?: 'unknown' }} — aaguid: {{ c.aaguid ?: 'n/a' }}
            <form method="post" action="{{ path('webauthn_revoke', {'id': c.id}) }}" style="display:inline;">
              {{ btn.button('webauthn.revoke'|trans, 'danger', null, {'type':'submit','class':'btn-sm'}) }}
            </form>
          </li>
        {% else %}
          <li>{{ 'webauthn.no_credentials'|trans }}</li>
        {% endfor %}
      </ul>
    </div>

    <div class="mt-4">
      {{ btn.button('webauthn.register'|trans, 'primary', null, {}) }}
    </div>
  </div>

  <script>
    document.getElementById('registerBtn').addEventListener('click', async function(){
      // Start
      const start = await fetch('{{ path('webauthn_register_start') }}', {method:'POST'});
      const opts = await start.json();
      // Decode challenge
      opts.challenge = Uint8Array.from(window.atob(opts.challenge.replace(/-/g,'+').replace(/_/g,'/')), c=>c.charCodeAt(0));
      opts.user.id = Uint8Array.from(window.atob(opts.user.id.replace(/-/g,'+').replace(/_/g,'/')), c=>c.charCodeAt(0));

      const cred = await navigator.credentials.create({publicKey: opts});
      const response = cred.response;

      const clientDataJSON = btoa(String.fromCharCode(...new Uint8Array(response.clientDataJSON)));
      const attestationObject = btoa(String.fromCharCode(...new Uint8Array(response.attestationObject)));
      const rawId = btoa(String.fromCharCode(...new Uint8Array(cred.rawId)));

      // Try to extract fmt quickly if present in object (best-effort)
      let fmt = null;
      try { fmt = cred.response.getClientExtensionResults && cred.response.getClientExtensionResults().fmt; } catch(e){}

      await fetch('{{ path('webauthn_register_finish') }}', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          attestationObject: attestationObject,
          clientDataJSON: clientDataJSON,
          rawId: rawId,
          publicKey: '',
          fmt: fmt
        })
      });

      location.reload();
    });
  </script>

{% endblock %}
