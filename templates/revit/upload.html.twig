{% extends 'base.html.twig' %}

{% block title %}{{ 'revit.upload_title'|trans }}{% endblock %}

{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1><i class="bi bi-cloud-upload"></i> {{ 'revit.upload_header'|trans }}</h1>
                {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_revit_files')}) }}
            </div>
            <p class="text-muted">{{ 'revit.upload_instruction'|trans }}</p>

            {% for message in app.flashes('error') %}
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle"></i> {{ message|trans }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle"></i> {{ message|trans }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <div class="card">
                <div class="card-body">
                    <form method="POST" enctype="multipart/form-data" id="uploadForm">
                        <input type="hidden" name="_token" value="{{ csrf_token('revit_upload') }}">
                        <div class="mb-3">
                            <label for="revit_file" class="form-label">{{ 'revit.select_file'|trans }}</label>
                            <input type="file"
                                   class="form-control"
                                   id="revit_file"
                                   name="revit_file"
                                   accept=".ifc,.json,.rvt"
                                   required>
                            <div class="form-text">
                                {{ 'revit.allowed_formats'|trans({'%size%':'100 MB'}) }}
                            </div>
                        </div>

                        <div id="fileInfo" class="alert alert-info" style="display: none;"
                             data-unknown-text="{{ 'revit.upload.unknown'|trans }}">
                            <strong>{{ 'revit.upload.selected_file'|trans }}:</strong>
                            <ul class="mb-0 mt-2">
                                <li>{{ 'revit.label.name'|trans }}: <span id="fileName"></span></li>
                                <li>{{ 'revit.label.size'|trans }}: <span id="fileSize"></span></li>
                                <li>{{ 'revit.label.type'|trans }}: <span id="fileType"></span></li>
                            </ul>
                        </div>

                        <div class="card bg-light mb-3">
                            <div class="card-body">
                                <h6 class="card-title">
                                    <i class="bi bi-info-circle"></i> {{ 'common.information'|trans }}
                                </h6>
                                <ul class="small mb-0">
                                    <li><strong>IFC (Industry Foundation Classes):</strong> {{ 'revit.ifc_description'|trans }}</li>
                                    <li><strong>JSON:</strong> {{ 'revit.json_description'|trans }}</li>
                                    <li><strong>RVT:</strong> {{ 'revit.rvt_description'|trans }}</li>
                                </ul>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                                {% import 'partials/_button.html.twig' as btn %}
                                {{ btn.button('revit.upload_new'|trans, 'primary', 'bi-upload', {'type':'submit','id':'submitBtn','data-uploading-text': ('revit.upload.uploading'|trans)}) }}
                                {{ btn.button('revit.files'|trans, 'secondary', 'bi-folder', {'href': path('app_revit_files')}) }}
                        </div>
                    </form>
                </div>
            </div>

            <div class="mt-4">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-lightbulb"></i> {{ 'revit.how.title'|trans }}
                    </div>
                    <div class="card-body">
                        <ol>
                            <li>{{ 'revit.how.step1'|trans }}</li>
                            <li>{{ 'revit.how.step2'|trans }}</li>
                            <li>{{ 'revit.how.step3'|trans }}
                                <ul>
                                    <li>{{ 'revit.how.step3.item1'|trans }}</li>
                                    <li>{{ 'revit.how.step3.item2'|trans }}</li>
                                    <li>{{ 'revit.how.step3.item3'|trans }}</li>
                                </ul>
                            </li>
                            <li>{{ 'revit.how.step4'|trans }}</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
        document.getElementById('revit_file').addEventListener('change', function(e) {
    const file = e.target.files[0];
    const fileInfo = document.getElementById('fileInfo');

    if (file) {
        document.getElementById('fileName').textContent = file.name;
        document.getElementById('fileSize').textContent = formatFileSize(file.size);
        const unknownText = fileInfo ? fileInfo.dataset.unknownText || 'Unknown' : 'Unknown';
        document.getElementById('fileType').textContent = file.type || unknownText;
        fileInfo.style.display = 'block';
    } else {
        fileInfo.style.display = 'none';
    }
});

document.getElementById('uploadForm').addEventListener('submit', function(e) {
    const submitBtn = document.getElementById('submitBtn');
    submitBtn.disabled = true;
    const uploadingText = submitBtn.dataset.uploadingText || 'Uploading...';
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> ' + uploadingText;
});

function formatFileSize(bytes) {
    if (bytes === 0) return '0 Bytes';
    const k = 1024;
    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
}
</script>
{% endblock %}
