{% extends 'base.html.twig' %}

{% block title %}{{ 'revit.details'|trans }} - {{ file.originalFilename }}{% endblock %}

{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_revit_files') }}">{{ 'revit.files'|trans }}</a></li>
            <li class="breadcrumb-item active">{{ file.originalFilename }}</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-file-earmark-text"></i> {{ file.originalFilename }}</h1>
        <div class="btn-group" role="group">
            {% if file.status == 'error' %}
                <form method="POST" action="{{ path('app_revit_file_reprocess', {id: file.id}) }}" style="display: inline;">
                    {{ btn.button('revit.reprocess'|trans, 'warning', 'bi-bi-arrow-clockwise', {'type':'submit'}) }}
                </form>
            {% endif %}
            <form method="POST"
                  action="{{ path('app_revit_file_delete', {id: file.id}) }}"
                  onsubmit="return confirm('{{ 'revit.confirm_delete'|trans }}')"
                  style="display: inline;">
                {{ btn.button('revit.delete'|trans, 'danger', 'bi-bi-trash', {'type':'submit'}) }}
            </form>
        </div>
    </div>

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> {{ message|trans }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> {{ message|trans }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="row">
        <div class="col-md-4">
            <div class="card mb-3">
                <div class="card-header">
                    <i class="bi bi-info-circle"></i> {{ 'revit.info_general'|trans }}
                </div>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <strong>{{ 'revit.label.type'|trans }}:</strong>
                        <span class="badge bg-secondary float-end">{{ file.fileType|upper }}</span>
                    </li>
                    <li class="list-group-item">
                        <strong>{{ 'revit.label.size'|trans }}:</strong>
                        <span class="float-end">{{ file.fileSizeFormatted }}</span>
                    </li>
                    <li class="list-group-item">
                        <strong>{{ 'revit.label.status'|trans }}:</strong>
                        <span class="float-end">
                            {% if file.status == 'completed' %}
                                <span class="badge bg-success">{{ 'revit.status.completed'|trans }}</span>
                            {% elseif file.status == 'processing' %}
                                <span class="badge bg-warning text-dark">{{ 'revit.status.processing'|trans }}</span>
                            {% elseif file.status == 'pending' %}
                                <span class="badge bg-info text-dark">{{ 'revit.status.pending'|trans }}</span>
                            {% elseif file.status == 'error' %}
                                <span class="badge bg-danger">{{ 'revit.status.error'|trans }}</span>
                            {% endif %}
                        </span>
                    </li>
                    <li class="list-group-item">
                        <strong>{{ 'revit.label.hash'|trans }}:</strong>
                        <br>
                        <code class="small">{{ file.fileHash }}</code>
                    </li>
                    <li class="list-group-item">
                        <strong>{{ 'revit.label.uploaded_by'|trans }}:</strong>
                        <span class="float-end">{{ file.uploadedBy.username }}</span>
                    </li>
                    <li class="list-group-item">
                        <strong>{{ 'revit.label.uploaded_at'|trans }}:</strong>
                        <span class="float-end">{{ file.uploadedAt|date('d/m/Y H:i:s') }}</span>
                    </li>
                    {% if file.processedAt %}
                        <li class="list-group-item">
                            <strong>{{ 'revit.label.processed_at'|trans }}:</strong>
                            <span class="float-end">{{ file.processedAt|date('d/m/Y H:i:s') }}</span>
                        </li>
                    {% endif %}
                </ul>
            </div>

            {% if file.metadata %}
                <div class="card mb-3">
                    <div class="card-header">
                        <i class="bi bi-database"></i> {{ 'revit.metadata'|trans }}
                    </div>
                    <div class="card-body">
                                {% if file.metadata.project_name is defined %}
                                    <p><strong>{{ 'revit.label.project'|trans }}:</strong> {{ file.metadata.project_name }}</p>
                                {% endif %}
                        {% if file.metadata.version is defined %}
                            <p><strong>{{ 'revit.label.version'|trans }}:</strong> {{ file.metadata.version }}</p>
                        {% endif %}
                        {% if file.metadata.elements_count is defined %}
                            <p><strong>{{ 'revit.label.elements'|trans }}:</strong> {{ file.metadata.elements_count }}</p>
                        {% endif %}
                        {% if file.metadata.categories is defined %}
                            <p><strong>{{ 'revit.label.categories'|trans }}:</strong></p>
                            <ul>
                                {% for category in file.metadata.categories %}
                                    <li>{{ category }}</li>
                                {% endfor %}
                            </ul>
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-md-8">
            {% if file.status == 'error' and file.errorMessage %}
                <div class="alert alert-danger">
                    <h5><i class="bi bi-exclamation-triangle"></i> {{ 'revit.processing_error'|trans }}</h5>
                    <p class="mb-0">{{ file.errorMessage }}</p>
                </div>
            {% endif %}

            {% if file.processingResult %}
                <div class="card mb-3">
                    <div class="card-header">
                        <i class="bi bi-clipboard-check"></i> {{ 'revit.processing_result'|trans }}
                    </div>
                    <div class="card-body">
                        {% if file.processingResult.created is defined %}
                            <div class="row text-center mb-3">
                                <div class="col-md-4">
                                    <div class="card bg-success text-white">
                                        <div class="card-body">
                                            <h3>{{ file.processingResult.created }}</h3>
                                            <p class="mb-0">{{ 'revit.processing.created'|trans }}</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card bg-warning text-dark">
                                        <div class="card-body">
                                            <h3>{{ file.processingResult.skipped|default(0) }}</h3>
                                            <p class="mb-0">{{ 'revit.processing.skipped'|trans }}</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="card bg-info text-white">
                                        <div class="card-body">
                                            <h3>{{ file.processingResult.total|default(0) }}</h3>
                                            <p class="mb-0">{{ 'revit.processing.total'|trans }}</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endif %}

                        {% if file.processingResult.elements is defined %}
                            <h5>{{ 'revit.processed_elements'|trans }}</h5>
                            <div class="table-responsive">
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                                    <th>{{ 'revit.table.name'|trans }}</th>
                                                    <th>{{ 'revit.table.category'|trans }}</th>
                                                    <th>{{ 'revit.table.quantity'|trans }}</th>
                                                    <th>{{ 'revit.table.unit'|trans }}</th>
                                                    <th>{{ 'revit.table.status'|trans }}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for element in file.processingResult.elements|slice(0, 50) %}
                                            <tr>
                                                <td>{{ element.name|default('N/A') }}</td>
                                                <td>{{ element.category|default('N/A') }}</td>
                                                <td>{{ element.quantity|default('N/A') }}</td>
                                                <td>{{ element.unit|default('N/A') }}</td>
                                                <td>
                                                    {% if element.created %}
                                                        <span class="badge bg-success">{{ 'revit.table.created'|trans }}</span>
                                                    {% else %}
                                                        <span class="badge bg-warning text-dark">{{ 'revit.table.skipped'|trans }}</span>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                            {% if file.processingResult.elements|length > 50 %}
                                <p class="text-muted small">
                                    {{ 'revit.showing'|trans({'%shown%': 50, '%total%': file.processingResult.elements|length}) }}
                                </p>
                            {% endif %}
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            {% if file.status == 'pending' %}
                <div class="alert alert-info">
                    <i class="bi bi-hourglass-split"></i> {{ 'revit.status.pending'|trans }}
                    {{ 'revit.processing_will_start'|trans }}
                </div>
            {% endif %}

            {% if file.status == 'processing' %}
                <div class="alert alert-warning">
                    <i class="bi bi-arrow-repeat"></i> {{ 'revit.status.processing'|trans }}
                    {{ 'revit.update_to_see_progress'|trans }}
                </div>
            {% endif %}

            <div class="card">
                <div class="card-header">
                    <i class="bi bi-code-square"></i> {{ 'revit.info_technical'|trans }}
                </div>
                <div class="card-body">
                    <p><strong>{{ 'revit.label.stored_filename'|trans }}:</strong> <code>{{ file.storedFilename }}</code></p>
                    <p><strong>{{ 'revit.label.path'|trans }}:</strong> <code>{{ file.filePath }}</code></p>
                    <p class="mb-0"><strong>{{ 'revit.label.file_id'|trans }}:</strong> <code>{{ file.id }}</code></p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
