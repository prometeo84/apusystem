{% extends 'base.html.twig' %}

{% block title %}{{ 'revit.files'|trans }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-folder"></i> {{ 'revit.files'|trans }}</h1>
        <a href="{{ path('app_revit_upload') }}" class="btn btn-primary">
            <i class="bi bi-cloud-upload"></i> {{ 'revit.upload_new'|trans }}
        </a>
    </div>

    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle"></i> {{ message|trans }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle"></i> {{ message|trans }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% if files is empty %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> {{ 'revit.no_files'|trans }}
            <a href="{{ path('app_revit_upload') }}" class="alert-link">{{ 'revit.upload_first'|trans }}</a>.
        </div>
    {% else %}
        <div class="card">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                                <tr>
                                <th width="5%"><i class="bi bi-file-earmark"></i></th>
                                <th width="30%">{{ 'revit.table.file'|trans }}</th>
                                <th width="10%">{{ 'revit.table.type'|trans }}</th>
                                <th width="10%">{{ 'common.size'|trans }}</th>
                                <th width="15%">{{ 'revit.label.status'|trans }}</th>
                                <th width="15%">{{ 'revit.label.date'|trans }}</th>
                                <th width="15%" class="text-end">{{ 'revit.table.actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for file in files %}
                                <tr>
                                    <td class="text-center">
                                        {% if file.fileType == 'ifc' %}
                                            <i class="bi bi-file-code text-primary fs-4"></i>
                                        {% elseif file.fileType == 'json' %}
                                            <i class="bi bi-file-code-fill text-success fs-4"></i>
                                        {% elseif file.fileType == 'rvt' %}
                                            <i class="bi bi-file-earmark-binary text-info fs-4"></i>
                                        {% else %}
                                            <i class="bi bi-file-earmark text-secondary fs-4"></i>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <strong>{{ file.originalFilename }}</strong>
                                        <br>
                                        <small class="text-muted">{{ file.storedFilename }}</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary">{{ file.fileType|upper }}</span>
                                    </td>
                                    <td>{{ file.fileSizeFormatted }}</td>
                                    <td>
                                        {% if file.status == 'completed' %}
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> {{ 'revit.status.completed'|trans }}
                                            </span>
                                        {% elseif file.status == 'processing' %}
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-arrow-repeat"></i> {{ 'revit.status.processing'|trans }}
                                            </span>
                                        {% elseif file.status == 'pending' %}
                                            <span class="badge bg-info text-dark">
                                                <i class="bi bi-hourglass-split"></i> {{ 'revit.status.pending'|trans }}
                                            </span>
                                        {% elseif file.status == 'error' %}
                                            <span class="badge bg-danger">
                                                <i class="bi bi-exclamation-triangle"></i> {{ 'revit.status.error'|trans }}
                                            </span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <small>{{ file.uploadedAt|date('d/m/Y H:i') }}</small>
                                    </td>
                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="{{ path('app_revit_file_detail', {id: file.id}) }}"
                                               class="btn btn-outline-primary"
                                               title="{{ 'revit.view_details'|trans }}">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            {% if file.status == 'error' %}
                                                <form method="POST"
                                                      action="{{ path('app_revit_file_reprocess', {id: file.id}) }}"
                                                      style="display: inline;">
                                                    <button type="submit"
                                                            class="btn btn-outline-warning"
                                                            title="{{ 'revit.reprocess'|trans }}">
                                                        <i class="bi bi-arrow-clockwise"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                            <form method="POST"
                                                  action="{{ path('app_revit_file_delete', {id: file.id}) }}"
                                                  onsubmit="return confirm('{{ 'revit.confirm_delete'|trans }}')"
                                                  style="display: inline;">
                                                <button type="submit"
                                                        class="btn btn-outline-danger"
                                                        title="{{ 'revit.delete'|trans }}">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <div class="row">
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title">{{ files|length }}</h5>
                            <p class="card-text text-muted">{{ 'revit.total_files'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-success">
                                {{ files|filter(f => f.status == 'completed')|length }}
                            </h5>
                            <p class="card-text text-muted">{{ 'revit.completed_files'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-warning">
                                {{ files|filter(f => f.status == 'processing' or f.status == 'pending')|length }}
                            </h5>
                            <p class="card-text text-muted">{{ 'revit.in_progress_files'|trans }}</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center">
                        <div class="card-body">
                            <h5 class="card-title text-danger">
                                {{ files|filter(f => f.status == 'error')|length }}
                            </h5>
                            <p class="card-text text-muted">{{ 'revit.error_files'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
