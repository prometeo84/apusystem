{% extends 'base.html.twig' %}

{% block title %}{{ 'security_2fa.regenerate_title'|trans }}{% endblock %}

{% block body %}
{% import 'partials/_button.html.twig' as btn %}
  <div class="container py-4">
    <h1>{{ 'security_2fa.regenerate_header'|trans }}</h1>
    <p>{{ 'security_2fa.regenerate_instructions'|trans }}</p>

    <form method="post">
      <input type="hidden" name="_token" value="{{ csrf_token('regenerate_recovery') }}">
      <div class="mb-3">
        <label class="form-label">{{ 'security_2fa.current_password'|trans }}</label>
        <input name="current_password" type="password" class="form-control" required />
      </div>
      <div class="d-flex gap-2">
        {{ btn.button('security_2fa.regenerate_button'|trans, 'primary', null, {}) }}
        {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_security')}) }}
      </div>
    </form>
  </div>
{% endblock %}
