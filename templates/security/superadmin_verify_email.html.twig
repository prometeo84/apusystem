{% extends 'base.html.twig' %}

{% block title %}Verificación de email — Superadmin{% endblock %}

{% block body %}
  <div class="container py-4">
    <h1>Verificación adicional para superadmin</h1>
    <p>Se ha enviado un código temporal a tu correo. Ingresa el código para completar el inicio de sesión.</p>

    <form method="post">
      <div class="mb-3">
        <label class="form-label">Código</label>
        <input name="code" class="form-control" required />
      </div>
      <button class="btn btn-primary">Verificar</button>
    </form>

    {% if expires %}
      <p class="mt-3"><small>El código expira: {{ expires }}</small></p>
    {% endif %}
  </div>
{% endblock %}
