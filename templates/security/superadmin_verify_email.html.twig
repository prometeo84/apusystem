{% extends 'base.html.twig' %}

{% block title %}{{ 'security.superadmin_verify.title'|trans }}{% endblock %}

{% block body %}
  <div class="container py-4">
    <h1>{{ 'security.superadmin_verify.header'|trans }}</h1>
    <p>{{ 'security.superadmin_verify.instruction'|trans }}</p>

    <form method="post">
      <div class="mb-3">
        <label class="form-label">{{ 'security.superadmin_verify.code_label'|trans }}</label>
        <input name="code" class="form-control" required autocomplete="one-time-code" />
      </div>
      <button class="btn btn-primary">{{ 'security.superadmin_verify.verify'|trans }}</button>
    </form>

    {% if expires is not null %}
      {# Use the date filter to obtain UNIX timestamps safely from strings or DateTime objects #}
      {% set now_ts = "now"|date('U') %}
      {% set expires_ts = expires|date('U') %}
      {% set remaining = expires_ts - now_ts %}
      {% if remaining > 0 %}
        {% set minutes = (remaining / 60)|round(0, 'ceil') %}
        <p class="mt-3"><small>{{ 'security.superadmin_verify.expires_in'|trans({'%minutes%': minutes, '%time%': expires|date('H:i')}) }}</small></p>
      {% else %}
        <p class="mt-3"><small>{{ 'security.superadmin_verify.expired'|trans }}</small></p>
      {% endif %}
    {% endif %}
  </div>
{% endblock %}
