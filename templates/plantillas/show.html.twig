{% extends 'base.html.twig' %}
{% block title %}{{ plantilla.nombre }} - {{ project.nombre }}{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container-fluid mt-4">
    {# Breadcrumb + cabecera #}
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_project_index') }}">{{ 'project.title'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_project_show', {id: project.id}) }}">{{ project.nombre }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_plantilla_index', {projectId: project.id}) }}">{{ 'plantilla.title'|trans }}</a></li>
            <li class="breadcrumb-item active">{{ plantilla.nombre }}</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-0"><i class="bi bi-layout-text-sidebar"></i> {{ plantilla.nombre }}</h1>
            {% if plantilla.descripcion %}<p class="text-muted mb-0">{{ plantilla.descripcion }}</p>{% endif %}
        </div>
        <div class="d-flex gap-2">
            {{ btn.button('plantilla.edit'|trans, 'outline-primary', 'bi-pencil', {'href': path('app_plantilla_edit', {projectId: project.id, id: plantilla.id}), 'class':'btn-sm'}) }}
            {# Duplicar #}
            <form method="POST" action="{{ path('app_plantilla_duplicate', {projectId: project.id, id: plantilla.id}) }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('plantilla_dup_' ~ plantilla.id) }}">
                {{ btn.button('plantilla.duplicate'|trans, 'outline-secondary', 'bi-copy', {'type':'submit', 'class':'btn-sm'}) }}
            </form>
            {# Reporte #}
            {{ btn.button('report.generate'|trans, 'success', 'bi-file-earmark-bar-graph', {'href': path('app_report_plantilla', {projectId: project.id, id: plantilla.id}), 'class':'btn-sm'}) }}
            {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_plantilla_index', {projectId: project.id}), 'class':'btn-sm'}) }}
        </div>
    </div>

    {% include 'partials/_flashes.html.twig' %}

    <div class="row">
        {# Lista de rubros de la plantilla #}
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-list-ol"></i> {{ 'plantilla.rubros'|trans }}</span>
                    <strong class="fs-5">${{ plantilla.totalPresupuesto|number_format(2, '.', ',') }}</strong>
                </div>
                {% if plantilla.plantillaRubros|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>{{ 'rubro.col_code'|trans }}</th>
                                <th>{{ 'rubro.col_name'|trans }}</th>
                                <th class="text-center">{{ 'rubro.col_unit'|trans }}</th>
                                <th class="text-end">{{ 'plantilla.col_cantidad'|trans }}</th>
                                <th class="text-end">{{ 'plantilla.col_precio_unit'|trans }}</th>
                                <th class="text-end">{{ 'plantilla.col_total'|trans }}</th>
                                <th class="text-center">{{ 'common.actions'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for pr in plantilla.plantillaRubros %}
                            <tr>
                                <td class="text-muted">{{ loop.index }}</td>
                                <td><code>{{ pr.rubro.codigo }}</code></td>
                                <td>
                                    <strong>{{ pr.rubro.nombre }}</strong>
                                    {% if pr.apuItem %}
                                        <br><small class="text-success"><i class="bi bi-check-circle"></i> APU</small>
                                    {% else %}
                                        <br><small class="text-warning"><i class="bi bi-exclamation-circle"></i> {{ 'plantilla.apu_pending'|trans }}</small>
                                    {% endif %}
                                </td>
                                <td class="text-center"><span class="badge bg-secondary">{{ pr.rubro.unidad }}</span></td>
                                <td class="text-end">{{ pr.cantidad|number_format(2) }}</td>
                                <td class="text-end">
                                    {% if pr.apuItem %}
                                        ${{ pr.precioUnitario|number_format(2) }}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="text-end fw-bold">
                                    {% if pr.apuItem %}
                                        ${{ pr.totalCosto|number_format(2) }}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    {% if pr.apuItem %}
                                        {{ btn.button('', 'outline-primary', 'bi-calculator', {'href': path('app_apu_edit', {id: pr.apuItem.id}), 'class':'btn-sm', 'title': 'apu.edit'|trans}) }}
                                    {% else %}
                                        {{ btn.button('', 'warning', 'bi-calculator-fill', {'href': path('app_apu_create_for_rubro', {plantillaRubroId: pr.id}), 'class':'btn-sm', 'title': 'plantilla.create_apu'|trans}) }}
                                    {% endif %}
                                    <form method="POST" action="{{ path('app_plantilla_remove_rubro', {projectId: project.id, id: plantilla.id, prId: pr.id}) }}" class="d-inline"
                                          onsubmit="return confirm('{{ 'plantilla.confirm_remove_rubro'|trans }}')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('remove_rubro_' ~ pr.id) }}">
                                        {{ btn.button('', 'outline-danger', 'bi-trash', {'type':'submit', 'class':'btn-sm'}) }}
                                    </form>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot>
                            <tr class="table-primary fw-bold">
                                <td colspan="6" class="text-end">{{ 'plantilla.total_presupuesto'|trans }}</td>
                                <td class="text-end fs-5">${{ plantilla.totalPresupuesto|number_format(2, '.', ',') }}</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
                {% else %}
                <div class="card-body text-center py-4">
                    <i class="bi bi-list-check display-4 text-muted"></i>
                    <p class="text-muted mt-2">{{ 'plantilla.no_rubros'|trans }}</p>
                </div>
                {% endif %}
            </div>
        </div>

        {# Panel derecho: agregar rubro #}
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <i class="bi bi-plus-circle"></i> {{ 'plantilla.add_rubro'|trans }}
                </div>
                <div class="card-body">
                    {% if rubrosDisponibles|length > 0 %}
                    <form method="POST" action="{{ path('app_plantilla_add_rubro', {projectId: project.id, id: plantilla.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('add_rubro_' ~ plantilla.id) }}">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">{{ 'plantilla.select_rubro'|trans }}</label>
                            <select class="form-select" name="rubro_id" required>
                                <option value="">{{ 'common.select'|trans }}</option>
                                {% for rubro in rubrosDisponibles %}
                                    {% if rubro.id not in rubrosAgregados %}
                                    <option value="{{ rubro.id }}">{{ rubro.codigo }} — {{ rubro.nombre }} ({{ rubro.unidad }})</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">{{ 'plantilla.col_cantidad'|trans }}</label>
                            <input type="number" class="form-control" name="cantidad" value="1.00" step="0.01" min="0.01" required>
                        </div>
                        {{ btn.button('plantilla.add_rubro'|trans, 'primary', 'bi-plus', {'type':'submit', 'class':'w-100'}) }}
                    </form>
                    {% else %}
                    <p class="text-muted small">{{ 'plantilla.no_rubros_available'|trans }}</p>
                    {{ btn.button('rubro.new'|trans, 'outline-primary', 'bi-tag-fill', {'href': path('app_rubro_create'), 'class':'w-100'}) }}
                    {% endif %}
                </div>
            </div>

            {# Peligro: eliminar #}
            <div class="card mt-3">
                <div class="card-header text-danger fw-semibold">
                    <i class="bi bi-exclamation-triangle"></i> {{ 'common.danger_zone'|trans }}
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ path('app_plantilla_delete', {projectId: project.id, id: plantilla.id}) }}"
                          onsubmit="return confirm('{{ 'plantilla.confirm_delete'|trans }}')">
                        <input type="hidden" name="_token" value="{{ csrf_token('plantilla_delete_' ~ plantilla.id) }}">
                        {{ btn.button('common.delete'|trans ~ ' plantilla', 'danger', 'bi-trash', {'type':'submit', 'class':'w-100'}) }}
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
