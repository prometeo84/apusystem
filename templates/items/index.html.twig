{% extends 'base.html.twig' %}
{% block title %}{{ 'rubro.title'|trans }} - APU System{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
{% import 'partials/_pagination.html.twig' as pager %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><i class="bi bi-tags"></i> {{ 'rubro.title'|trans }}</h1>
        <div class="d-flex gap-2 align-items-center">
        {% if is_granted('ROLE_ADMIN') %}
            {% if can_create_item is defined and not can_create_item %}
                {{ btn.button('rubro.new'|trans, 'secondary', 'bi-plus-circle', {'href': '#', 'class':'disabled', 'title': 'flash.tenant_item_limit_reached'|trans}) }}
                {% if device.show_new_item_link %}
                    <a href="#" class="d-inline d-md-none" aria-hidden="true">{{ 'common.new-item-link'|trans }}</a>
                {% endif %}
            {% else %}
                {{ btn.button('rubro.new'|trans, 'primary', 'bi-plus-circle', {'href': path('app_item_create')}) }}
                {% if device.show_new_item_link %}
                    <a href="/items/create" class="d-inline d-md-none" aria-hidden="true">{{ 'common.new-item-link'|trans }}</a>
                {% endif %}
            {% endif %}
        {% endif %}
            {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_dashboard')}) }}
        </div>
    </div>

    {% include 'partials/_flashes.html.twig' %}

    {% if items|length > 0 %}
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'rubro.col_code'|trans }}</th>
                        <th>{{ 'rubro.col_name'|trans }}</th>
                        <th>{{ 'rubro.col_unit'|trans }}</th>
                        <th>{{ 'rubro.col_type'|trans }}</th>
                        <th>{{ 'common.created_at'|trans }}</th>
                        <th class="text-center">{{ 'common.actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for item in items %}
                    <tr>
                        <td><code>{{ item.code }}</code></td>
                        <td><strong>{{ item.name }}</strong>
                            {% if item.description %}<br><small class="text-muted">{{ item.description|slice(0,80) }}{% if item.description|length > 80 %}…{% endif %}</small>{% endif %}
                        </td>
                        <td><span class="badge bg-secondary">{{ item.unit }}</span></td>
                        <td>
                            <span class="badge bg-{{ item.type == 'general' ? 'info' : 'primary' }}">
                                {{ ('rubro.tipo.' ~ item.type)|trans }}
                            </span>
                        </td>
                        <td>{{ item.createdAt|date('d/m/Y') }}</td>
                        <td class="text-center">
                            {% if is_granted('ROLE_ADMIN') %}
                                                        {{ btn.button('', 'outline-secondary', 'bi-pencil', {'href': path('app_item_edit', {id: item.id}), 'class':'btn-sm', 'title': 'common.edit'|trans}) }}
                            <form method="POST" action="{{ path('app_item_delete', {id: item.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('rubro_delete_' ~ item.id) }}">
                                {{ btn.button('', 'outline-danger', 'bi-trash', {'type':'submit', 'class':'btn-sm', 'title': 'common.delete'|trans}) }}
                            </form>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% if totalPages is defined and totalPages > 1 %}
        <div class="card-footer d-flex justify-content-between align-items-center">
            {{ pager.info(currentPage, totalPages) }}
            {{ pager.render(currentPage, totalPages, 'app_item_index') }}
        </div>
        {% endif %}
    </div>
    {% else %}
    <div class="text-center py-5">
        <i class="bi bi-tags display-1 text-muted"></i>
        <p class="text-muted mt-3 fs-5">{{ 'rubro.no_rubros'|trans }}</p>
        {% if is_granted('ROLE_ADMIN') %}
            {% if can_create_item is defined and not can_create_item %}
                {{ btn.button('rubro.new'|trans, 'secondary', 'bi-plus-circle', {'href': '#', 'class':'disabled', 'title': 'flash.tenant_item_limit_reached'|trans}) }}
            {% else %}
                {{ btn.button('rubro.new'|trans, 'primary', 'bi-plus-circle', {'href': path('app_item_create')}) }}
            {% endif %}
        {% endif %}
    </div>
    {% endif %}
</div>
{% endblock %}
