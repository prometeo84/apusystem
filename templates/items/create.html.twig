{% extends 'base.html.twig' %}
{% block title %}{{ 'rubro.new'|trans }} - APU System{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container mt-4" style="max-width:700px">
        <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-tag-fill"></i> {{ 'rubro.new'|trans }}</h1>
        {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_item_index')}) }}
    </div>
    {% include 'partials/_flashes.html.twig' %}
    <div class="card">
        <div class="card-body">
            <form method="POST" action="{{ path('app_item_create') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('rubro_create') }}">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-semibold">{{ 'rubro.col_code'|trans }} <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="codigo" maxlength="100" placeholder="Ej: 101.001" required>
                    </div>
                    <div class="col-md-8 mb-3">
                        <label class="form-label fw-semibold">{{ 'rubro.col_name'|trans }} <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" name="nombre" maxlength="255" required>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'common.description'|trans }}</label>
                    <textarea class="form-control" name="descripcion" rows="2"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'rubro.col_unit'|trans }} <span class="text-danger">*</span></label>
                    <select class="form-select" name="unidad" required>
                        <option value="">{{ 'common.select'|trans }}</option>
                        <option value="m²">m²</option>
                        <option value="m³">m³</option>
                        <option value="m">m (metro lineal)</option>
                        <option value="kg">kg</option>
                        <option value="u">u (unidad)</option>
                        <option value="GLB">GLB (global)</option>
                        <option value="h">h (hora)</option>
                        <option value="t">t (tonelada)</option>
                    </select>
                </div>
                <div class="text-end mt-4">
                    {{ btn.button('buttons.cancel'|trans, 'secondary', 'bi-x', {'href': path('app_item_index')}) }}
                    &nbsp;
                    {{ btn.button('rubro.save'|trans, 'primary', 'bi-save', {'type':'submit'}) }}
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
