{% extends 'base.html.twig' %}
{% block title %}{{ 'rubro.new'|trans }} - APU System{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container mt-4" style="max-width:700px">
        <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-tag-fill"></i> {{ 'rubro.new'|trans }}</h1>
        {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_item_index')}) }}
    </div>
    {% include 'partials/_flashes.html.twig' %}
    <div class="card">
        <div class="card-body">
            <form method="POST" action="{{ path('app_item_create') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('rubro_create') }}">
                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label class="form-label fw-semibold">{{ 'rubro.col_code'|trans }} <span class="text-danger">*</span></label>
                        <input type="text" class="form-control{% if fieldErrors.code is defined %} is-invalid{% endif %}" name="code" maxlength="100" placeholder="Ej: 101.001" required aria-invalid="{{ fieldErrors.code is defined ? 'true' : 'false' }}" value="{{ item is defined ? item.getCode() : '' }}">
                        {% if fieldErrors.code is defined %}
                            <div class="invalid-feedback">{{ fieldErrors.code[0]|trans({}, 'validators') }}</div>
                        {% endif %}
                    </div>
                    <div class="col-md-8 mb-3">
                        <label class="form-label fw-semibold">{{ 'rubro.col_name'|trans }} <span class="text-danger">*</span></label>
                        <input type="text" class="form-control{% if fieldErrors.name is defined %} is-invalid{% endif %}" name="name" maxlength="255" required aria-invalid="{{ fieldErrors.name is defined ? 'true' : 'false' }}" value="{{ item is defined ? item.getName() : '' }}">
                        {% if fieldErrors.name is defined %}
                            <div class="invalid-feedback">{{ fieldErrors.name[0]|trans({}, 'validators') }}</div>
                        {% endif %}
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'common.description'|trans }}</label>
                    <textarea class="form-control" name="description" rows="2"></textarea>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'rubro.col_unit'|trans }} <span class="text-danger">*</span></label>
                        <select class="form-select{% if fieldErrors.unit is defined %} is-invalid{% endif %}" name="unit" required aria-invalid="{{ fieldErrors.unit is defined ? 'true' : 'false' }}">
                        <option value="">{{ 'common.select'|trans }}</option>
                        {% set unit_map = { 'GLB':'units.GLB', 'h':'units.h', 'kg':'units.kg', 'm':'units.m', 'm²':'units.m2', 'm³':'units.m3', 't':'units.t', 'u':'units.u' } %}
                        {% for val, key in unit_map %}
                            <option value="{{ val }}">{{ key|trans }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'items.visibility.label'|trans }}</label>
                    <select class="form-select" name="visibility" id="visibility-select">
                        <option value="tenant">{{ 'items.visibility.tenant'|trans }}</option>
                        <option value="project">{{ 'items.visibility.project'|trans }}</option>
                    </select>
                </div>
                <div class="mb-3" id="project-select-group" style="display:none;">
                    <label class="form-label fw-semibold">{{ 'common.project_optional'|trans }}</label>
                    <select class="form-select" name="project_id">
                        <option value="">{{ 'common.select'|trans }}</option>
                        {% for p in projects %}
                            <option value="{{ p.id }}">{{ p.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                    <div class="text-end mt-4">
                    {{ btn.button('buttons.cancel'|trans, 'secondary', 'bi-x', {'href': path('app_item_index')}) }}
                    &nbsp;
                    {{ btn.button('rubro.save'|trans, 'primary', 'bi-save', {'type':'submit'}) }}
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function(){
            const form = document.querySelector('form[action="{{ path('app_item_create') }}"]');
            if (!form) return;
            form.addEventListener('submit', function(e){
                const code = form.querySelector('input[name="code"]').value.trim();
                const name = form.querySelector('input[name="name"]').value.trim();
                const unit = (form.querySelector('select[name="unit"]') || {}).value || '';
                let ok = true;

                function setErr(el, msg){
                    el.classList.add('is-invalid');
                    let fb = el.parentNode.querySelector('.invalid-feedback');
                    if (!fb) { fb = document.createElement('div'); fb.className = 'invalid-feedback'; el.parentNode.appendChild(fb); }
                    fb.textContent = msg;
                    el.setAttribute('aria-invalid', 'true');
                }
                function clearErr(el){
                    el.classList.remove('is-invalid');
                    const fb = el.parentNode.querySelector('.invalid-feedback'); if (fb) fb.remove();
                    el.setAttribute('aria-invalid', 'false');
                }

                const codeEl = form.querySelector('input[name="code"]');
                const nameEl = form.querySelector('input[name="name"]');
                const unitEl = form.querySelector('select[name="unit"]');

                clearErr(codeEl); clearErr(nameEl); clearErr(unitEl);

                if (!/^[A-Za-z0-9\-\_\.]+$/.test(code)) { setErr(codeEl, 'Invalid code'); ok = false; }
                if (!/^[\p{L}\d\s\-\.\_]+$/u.test(name)) { setErr(nameEl, 'Invalid name'); ok = false; }
                if (!unit || unit === '') { setErr(unitEl, 'Unit required'); ok = false; }

                if (!ok) e.preventDefault();
            });
        })();
    </script>
    <script>
        (function(){
            const vis = document.getElementById('visibility-select');
            const group = document.getElementById('project-select-group');
            if (!vis || !group) return;
            vis.addEventListener('change', function(){
                if (vis.value === 'project') group.style.display = 'block'; else group.style.display = 'none';
            });
        })();
    </script>
{% endblock %}
