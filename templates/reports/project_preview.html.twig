{% extends 'base.html.twig' %}
{% import 'partials/_button.html.twig' as btn %}
{% block title %}{{ 'report.full_project'|trans }} - {{ project.nombre }}{% endblock %}
{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-1">
                    <li class="breadcrumb-item"><a href="{{ path('app_project_index') }}">{{ 'project.title'|trans }}</a></li>
                    <li class="breadcrumb-item"><a href="{{ path('app_project_show', {id: project.id}) }}">{{ project.nombre }}</a></li>
                    <li class="breadcrumb-item active">{{ 'report.full_project'|trans }}</li>
                </ol>
            </nav>
            <h1 class="mb-0"><i class="bi bi-file-earmark-bar-graph"></i> {{ 'report.full_project'|trans }}</h1>
        </div>
        <div class="d-flex gap-2">
            {{ btn.button('report.download_pdf'|trans, 'danger', 'bi-file-earmark-pdf', {'href': path('app_report_project_full_pdf', {id: project.id}), 'class':'btn-gradient'}) }}
            {{ btn.button('report.download_excel'|trans, 'success', 'bi-file-earmark-excel', {'href': path('app_report_project_full_excel', {id: project.id}), 'class':'btn-gradient'}) }}
            {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_project_show', {id: project.id})}) }}
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="p-4" style="background:#fff;">
                {{ html|raw }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
