{% extends 'base.html.twig' %}

{% block title %}{{ 'project.title'|trans }} - APU System{% endblock %}

{% block body %}
{% import 'partials/_button.html.twig' as btn %}
{% import 'partials/_pagination.html.twig' as pager %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-folder2-open"></i> {{ 'project.title'|trans }}</h1>
        <div class="d-flex gap-2">
            {% if is_granted('ROLE_ADMIN') %}
            {{ btn.button('project.new'|trans, 'primary', 'bi-plus-circle', {'href': path('app_project_create')}) }}
            {% endif %}
            {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_dashboard')}) }}
        </div>
    </div>

    {% include 'partials/_flashes.html.twig' %}

    {% if projects|length > 0 %}
        <div class="card">
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>{{ 'project.col_name'|trans }}</th>
                            <th>{{ 'project.col_code'|trans }}</th>
                            <th>{{ 'project.col_client'|trans }}</th>
                            <th>{{ 'project.col_status'|trans }}</th>
                            <th class="text-end">{{ 'project.col_budget'|trans }}</th>
                            <th>{{ 'project.col_date'|trans }}</th>
                            <th class="text-center">{{ 'common.actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for project in projects %}
                            <tr>
                                <td><strong>{{ project.name }}</strong></td>
                                <td><span class="badge bg-secondary">{{ project.code }}</span></td>
                                <td>{{ project.client ?? '—' }}</td>
                                <td>
                                    {% set statusClass = {
                                        'planificacion': 'warning',
                                        'en_proceso': 'primary',
                                        'pausado': 'secondary',
                                        'finalizado': 'success'
                                    }[project.status] ?? 'secondary' %}
                                    <span class="badge bg-{{ statusClass }}">{{ ('project.status.' ~ project.status)|trans }}</span>
                                </td>
                                <td class="text-end">
                                    {% if project.totalBudget %}
                                        ${{ project.totalBudget|number_format(2, '.', ',') }}
                                    {% else %}
                                        —
                                    {% endif %}
                                </td>
                                <td>{{ project.createdAt|date('d/m/Y') }}</td>
                                <td class="text-center">
                                    {{ btn.button('', 'outline-primary', 'bi-eye', {'href': path('app_project_show', {id: project.id}), 'title': 'common.view'|trans, 'class':'btn-sm'}) }}
                                    {% if is_granted('ROLE_ADMIN') %}
                                    {{ btn.button('', 'outline-secondary', 'bi-pencil', {'href': path('app_project_edit', {id: project.id}), 'title': 'common.edit'|trans, 'class':'btn-sm'}) }}
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% if totalPages > 1 %}
            <div class="card-footer d-flex justify-content-between align-items-center">
                {{ pager.info(currentPage, totalPages) }}
                {{ pager.render(currentPage, totalPages, 'app_project_index') }}
            </div>
            {% endif %}
        </div>
    {% else %}
        <div class="text-center py-5">
            <i class="bi bi-folder2 display-1 text-muted"></i>
            <p class="text-muted mt-3 fs-5">{{ 'project.no_projects'|trans }}</p>
            {% if is_granted('ROLE_ADMIN') %}
            {{ btn.button('project.new'|trans, 'primary', 'bi-plus-circle', {'href': path('app_project_create')}) }}
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}
