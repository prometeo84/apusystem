<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <style>
    body { margin:0; background:#f3f4f6; font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif; }
    .wrap { max-width:600px; margin:24px auto; background:#fff; border-radius:8px; overflow:hidden; box-shadow:0 2px 12px rgba(0,0,0,.1); }
    .header { background:{{ primary_color|e('html') }}; color:#fff; padding:18px 24px; }
    .header h1 { margin:0; font-size:20px; }
    .body { padding:24px; }
    .greeting { color:#374151; margin-bottom:16px; }
    .info-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:20px; }
    .info-item { background:#f9fafb; border:1px solid #e5e7eb; border-radius:6px; padding:10px 12px; }
    .info-item .label { font-size:11px; text-transform:uppercase; letter-spacing:.06em; color:#9ca3af; margin-bottom:2px; }
    .info-item .value { font-size:13px; color:#374151; word-break:break-all; }
    .notice { background:#fef3c7; border-left:4px solid #f59e0b; border-radius:4px; padding:12px 14px; font-size:13px; color:#92400e; margin-top:16px; }
    .footer { background:#f9fafb; border-top:1px solid #e5e7eb; padding:14px 24px; font-size:12px; color:#9ca3af; text-align:center; }
  </style>
</head>
<body>
<div class="wrap">
  <div class="header">
    <h1>🔐 Nuevo inicio de sesión</h1>
  </div>
  <div class="body">
    <p class="greeting">Hola <strong>{{ user.getFullName() }}</strong>,</p>
    <p style="color:#374151;margin-bottom:16px;">Se ha detectado un nuevo inicio de sesión en tu cuenta de <strong>APU System</strong>.</p>
    <div class="info-grid">
      <div class="info-item" style="grid-column:1/-1">
        <div class="label">Fecha y hora</div>
        <div class="value">{{ dateTime|date('d/m/Y H:i:s') }} (UTC)</div>
      </div>
      <div class="info-item">
        <div class="label">Dirección IP</div>
        <div class="value">{{ ip }}</div>
      </div>
      <div class="info-item">
        <div class="label">Correo electrónico</div>
        <div class="value">{{ user.getEmail() }}</div>
      </div>
      <div class="info-item" style="grid-column:1/-1">
        <div class="label">Navegador / Dispositivo</div>
        <div class="value">{{ userAgent }}</div>
      </div>
    </div>
    <div class="notice">
      Si no fuiste tú, cambia tu contraseña inmediatamente y contacta al administrador del sistema.
    </div>
  </div>
  <div class="footer">APU System · Notificación de seguridad automática</div>
</div>
</body>
</html>
