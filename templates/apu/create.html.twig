{% extends 'base.html.twig' %}
{% import 'partials/_button.html.twig' as btn %}

{% block title %}{{ 'apu.create_title'|trans }} - APU System{% endblock %}

{% block body %}
<div class="container mt-4">
    <style>
        .apu-submit-floating { position: static; }
        @media (max-width: 768px) {
            .apu-submit-floating {
                position: fixed !important;
                left: 12px !important;
                right: 12px !important;
                bottom: 12px !important;
                display: flex !important;
                justify-content: flex-end !important;
                gap: .5rem !important;
                z-index: 2147483647 !important;
                pointer-events: auto !important;
            }
            .apu-submit-floating .btn { pointer-events: auto !important; }
            .main-content { padding-bottom: 180px !important; }
        }
    </style>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-calculator"></i> {{ 'apu.header'|trans }}</h1>
        {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_apu_index')}) }}
    </div>

    <form method="POST" id="apuForm">
        <input type="hidden" name="_token" value="{{ csrf_token('submit') }}">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                {{ 'apu.main_data'|trans }}
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label">{{ 'apu.column_description'|trans }}</label>
                            <input type="text" class="form-control" name="description"
                                   placeholder="{{ 'apu.example_description'|trans }}" required>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">{{ 'apu.unit'|trans }}</label>
                            <select class="form-select" name="unit" required>
                                <option value="">{{ 'common.select'|trans }}</option>
                                <option value="m²">{{ 'units.m2'|trans }}</option>
                                <option value="m³">{{ 'units.m3'|trans }}</option>
                                <option value="m">{{ 'units.m'|trans }}</option>
                                <option value="kg">{{ 'units.kg'|trans }}</option>
                                <option value="u">{{ 'units.u'|trans }}</option>
                                <option value="GLB">{{ 'units.GLB'|trans }}</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">K(H/U)</label>
                            <input type="number" step="0.0001" class="form-control" name="khu" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Rend. u/h</label>
                            <input type="number" step="0.0001" class="form-control" name="rendimiento_uh" required>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Sección EQUIPO -->
        <div class="card mb-3">
                <div class="card-header bg-warning">
                <i class="bi bi-tools"></i> {{ 'apu.equipment'|trans }}
                {{ btn.button('buttons.add'|trans, 'light', 'bi-plus', {'type':'button','onclick':'addEquipmentRow()','class':'btn-sm float-end'}) }}
            </div>
            <div class="card-body">
                <table class="table table-sm" id="equipmentTable">
                    <thead>
                        <tr>
                            <th style="width: 40%">{{ 'apu.col_description'|trans }}</th>
                            <th style="width: 10%">{{ 'apu.col_number'|trans }}</th>
                            <th style="width: 20%">{{ 'apu.col_rate'|trans }}</th>
                            <th style="width: 20%" class="text-end">{{ 'apu.col_subtotal'|trans }}</th>
                            <th style="width: 10%">{{ 'apu.actions'|trans }}</th>
                        </tr>
                    </thead>
        <div class="card mb-3">
                <div class="card-header bg-info text-white">
                <i class="bi bi-people"></i> {{ 'apu.labor'|trans }}
                {{ btn.button('buttons.add'|trans, 'light', 'bi-plus', {'type':'button','onclick':'addLaborRow()','class':'btn-sm float-end'}) }}
            </div>
            <div class="card-body">
                <table class="table table-sm" id="laborTable">
                    <thead>
                        <tr>
                            <th style="width: 40%">{{ 'apu.col_description'|trans }}</th>
                            <th style="width: 10%">{{ 'apu.col_number'|trans }}</th>
                            <th style="width: 20%">{{ 'apu.col_jh'|trans }}</th>
                            <th style="width: 20%" class="text-end">{{ 'apu.col_subtotal'|trans }}</th>
                            <th style="width: 10%">{{ 'apu.actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Filas dinámicas -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Sección MATERIALES -->
        <div class="card mb-3">
                <div class="card-header bg-success text-white">
                <i class="bi bi-box-seam"></i> {{ 'apu.materials'|trans }}
                {{ btn.button('buttons.add'|trans, 'light', 'bi-plus', {'type':'button','onclick':'addMaterialRow()','class':'btn-sm float-end'}) }}
            </div>
            <div class="card-body">
                <table class="table table-sm" id="materialTable">
                    <thead>
                        <tr>
                            <th style="width: 40%">{{ 'apu.col_description'|trans }}</th>
                            <th style="width: 15%">{{ 'apu.col_unit'|trans }}</th>
                            <th style="width: 15%">{{ 'apu.col_quantity'|trans }}</th>
                            <th style="width: 15%">{{ 'apu.col_unit_price'|trans }}</th>
                            <th style="width: 15%" class="text-end">{{ 'apu.col_subtotal'|trans }}</th>
                            <th style="width: 10%">{{ 'apu.actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Filas dinámicas -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Sección TRANSPORTE -->
        <div class="card mb-3">
                <div class="card-header bg-secondary text-white">
                <i class="bi bi-truck"></i> {{ 'apu.transport'|trans }}
                {{ btn.button('buttons.add'|trans, 'light', 'bi-plus', {'type':'button','onclick':'addTransportRow()','class':'btn-sm float-end'}) }}
            </div>
            <div class="card-body">
                <table class="table table-sm" id="transportTable">
                    <thead>
                        <tr>
                            <th style="width: 25%">{{ 'common.description'|trans }}</th>
                            <th style="width: 10%">{{ 'apu.col_unit'|trans }}</th>
                            <th style="width: 15%">{{ 'apu.col_quantity'|trans }}</th>
                            <th style="width: 15%">{{ 'apu.col_dmt'|trans }}</th>
                            <th style="width: 15%">{{ 'apu.col_rate_km'|trans }}</th>
                            <th style="width: 10%" class="text-end">{{ 'apu.col_subtotal'|trans }}</th>
                            <th style="width: 10%">{{ 'apu.actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <!-- Filas dinámicas -->
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Panel de Resumen de Costos -->
        <div class="card mb-3 border-primary shadow-sm">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="bi bi-calculator-fill"></i> {{ 'apu.cost_summary'|trans }}
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <table class="table table-sm mb-0">
                            <tbody>
                                <tr>
                                    <td>{{ 'apu.subtotal_equipment'|trans }}</td>
                                    <td class="text-end fw-semibold" id="summaryEquipment">$0.00</td>
                                </tr>
                                <tr>
                                    <td>{{ 'apu.subtotal_labor'|trans }}</td>
                                    <td class="text-end fw-semibold" id="summaryLabor">$0.00</td>
                                </tr>
                                <tr>
                                    <td>{{ 'apu.subtotal_materials'|trans }}</td>
                                    <td class="text-end fw-semibold" id="summaryMaterials">$0.00</td>
                                </tr>
                                <tr>
                                    <td>{{ 'apu.subtotal_transport'|trans }}</td>
                                    <td class="text-end fw-semibold" id="summaryTransport">$0.00</td>
                                </tr>
                                <tr class="table-primary">
                                    <td><strong>{{ 'apu.total_direct_costs'|trans }}</strong></td>
                                    <td class="text-end fw-bold fs-5" id="summaryTotal">$0.00</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="col-md-6">
                        <table class="table table-sm mb-0">
                            <tbody>
                                <tr>
                                    <td>
                                        <label class="form-label mb-0">{{ 'apu.utilidad_pct'|trans }}</label>
                                    </td>
                                    <td class="text-end" style="width: 45%">
                                        <div class="input-group input-group-sm">
                                              <input type="number" class="form-control text-end" id="utilidadPct"
                                                  name="utilidad_pct" value="20" min="0" max="100" step="0.1" style="pointer-events: auto;">
                                            <span class="input-group-text">%</span>
                                        </div>
                                    </td>
                                </tr>
                                <tr>
                                    <td>{{ 'apu.precio_calculo'|trans }}</td>
                                    <td class="text-end fw-semibold" id="summaryPrecioCalculo">$0.00</td>
                                </tr>
                                <tr class="table-success">
                                    <td><strong>{{ 'apu.precio_ofertado'|trans }} (USD)</strong></td>
                                    <td class="text-end">
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text">$</span>
                                              <input type="number" class="form-control text-end fw-bold" id="precioOfertado"
                                                  name="precio_ofertado" step="0.01" min="0" placeholder="0.00" style="pointer-events: auto;">
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>


    </form>
    <div class="d-flex gap-2 justify-content-end mt-3 apu-submit-floating">
        {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_apu_index')}) }}
        {{ btn.button('apu.save'|trans, 'primary', 'bi-save', {'type':'submit','form':'apuForm','class':'btn-gradient'}) }}
    </div>
</div>

<script>
let equipmentIndex = 0;
let laborIndex = 0;
let materialIndex = 0;
let transportIndex = 0;

function addEquipmentRow() {
    const tbody = document.querySelector('#equipmentTable tbody');
    const row = document.createElement('tr');
    row.innerHTML = `
        <td><input type="text" class="form-control form-control-sm" name="equipment[${equipmentIndex}][descripcion]" required></td>
        <td><input type="number" class="form-control form-control-sm calc-input" data-section="equipment" name="equipment[${equipmentIndex}][numero]" value="1" min="0" step="1" required></td>
        <td><input type="number" step="0.01" class="form-control form-control-sm calc-input" data-section="equipment" name="equipment[${equipmentIndex}][tarifa]" value="0" min="0" required></td>
        <td class="fw-semibold text-end row-subtotal">$0.00</td>
        <input type="hidden" name="equipment[${equipmentIndex}][c_hora]" class="row-hidden-total">
        <td>{{ btn.button('', 'danger', 'bi-trash', {'type':'button','onclick':'removeRow(this)','class':'btn-sm'}) }}</td>
    `;
    tbody.appendChild(row);
    equipmentIndex++;
    attachInputListeners(row);
    calculateTotals();
}

function addLaborRow() {
    const tbody = document.querySelector('#laborTable tbody');
    const row = document.createElement('tr');
    row.innerHTML = `
        <td><input type="text" class="form-control form-control-sm" name="labor[${laborIndex}][descripcion]" required></td>
        <td><input type="number" class="form-control form-control-sm calc-input" data-section="labor" name="labor[${laborIndex}][numero]" value="1" min="0" step="1" required></td>
        <td><input type="number" step="0.0001" class="form-control form-control-sm calc-input" data-section="labor" name="labor[${laborIndex}][jor_hora]" value="0" min="0" required></td>
        <td class="fw-semibold text-end row-subtotal">$0.00</td>
        <input type="hidden" name="labor[${laborIndex}][c_hora]" class="row-hidden-total">
        <td>{{ btn.button('', 'danger', 'bi-trash', {'type':'button','onclick':'removeRow(this)','class':'btn-sm'}) }}</td>
    `;
    tbody.appendChild(row);
    laborIndex++;
    attachInputListeners(row);
    calculateTotals();
}

function addMaterialRow() {
    const tbody = document.querySelector('#materialTable tbody');
    const row = document.createElement('tr');
    row.innerHTML = `
        <td><input type="text" class="form-control form-control-sm" name="materials[${materialIndex}][descripcion]" required></td>
        <td><input type="text" class="form-control form-control-sm" name="materials[${materialIndex}][unidad]" required></td>
        <td><input type="number" step="0.0001" class="form-control form-control-sm calc-input" data-section="material" name="materials[${materialIndex}][cantidad]" value="0" min="0" required></td>
        <td><input type="number" step="0.01" class="form-control form-control-sm calc-input" data-section="material" name="materials[${materialIndex}][precio_unitario]" value="0" min="0" required></td>
        <td class="fw-semibold text-end row-subtotal">$0.00</td>
        <td>{{ btn.button('', 'danger', 'bi-trash', {'type':'button','onclick':'removeRow(this)','class':'btn-sm'}) }}</td>
    `;
    tbody.appendChild(row);
    materialIndex++;
    attachInputListeners(row);
    calculateTotals();
}

function addTransportRow() {
    const tbody = document.querySelector('#transportTable tbody');
    const row = document.createElement('tr');
    row.innerHTML = `
        <td><input type="text" class="form-control form-control-sm" name="transport[${transportIndex}][descripcion]" required></td>
        <td><input type="text" class="form-control form-control-sm" name="transport[${transportIndex}][unidad]" required></td>
        <td><input type="number" step="0.0001" class="form-control form-control-sm calc-input" data-section="transport" name="transport[${transportIndex}][cantidad]" value="0" min="0" required></td>
        <td><input type="number" step="0.01" class="form-control form-control-sm calc-input" data-section="transport" name="transport[${transportIndex}][dmt]" value="0" min="0" required></td>
        <td><input type="number" step="0.01" class="form-control form-control-sm calc-input" data-section="transport" name="transport[${transportIndex}][tarifa_km]" value="0" min="0" required></td>
        <td class="fw-semibold text-end row-subtotal">$0.00</td>
        <td>{{ btn.button('', 'danger', 'bi-trash', {'type':'button','onclick':'removeRow(this)','class':'btn-sm'}) }}</td>
    `;
    tbody.appendChild(row);
    transportIndex++;
    attachInputListeners(row);
    calculateTotals();
}

function removeRow(btn) {
    btn.closest('tr').remove();
    calculateTotals();
}

function attachInputListeners(row) {
    row.querySelectorAll('.calc-input').forEach(input => {
        input.addEventListener('input', () => {
            updateRowSubtotal(row);
            calculateTotals();
        });
    });
}

function updateRowSubtotal(row) {
    const inputs = row.querySelectorAll('.calc-input');
    let subtotal = 0;
    if (inputs.length >= 2) {
        const vals = Array.from(inputs).map(i => parseFloat(i.value) || 0);
        subtotal = vals[0] * vals[1];
        if (inputs.length === 3) subtotal = vals[0] * vals[1] * vals[2]; // transport: cantidad * dmt * tarifa_km
    }
    const subtotalCell = row.querySelector('.row-subtotal');
    if (subtotalCell) subtotalCell.textContent = '$' + subtotal.toFixed(2);
    const hiddenInput = row.querySelector('.row-hidden-total');
    if (hiddenInput) hiddenInput.value = subtotal.toFixed(4);
}

function sectionTotal(tableId) {
    let total = 0;
    document.querySelectorAll(`#${tableId} tbody .row-subtotal`).forEach(cell => {
        total += parseFloat(cell.textContent.replace('$', '')) || 0;
    });
    return total;
}

function calculateTotals() {
    const eq = sectionTotal('equipmentTable');
    const lb = sectionTotal('laborTable');
    const mt = sectionTotal('materialTable');
    const tr = sectionTotal('transportTable');
    const total = eq + lb + mt + tr;
    const utilidad = parseFloat(document.getElementById('utilidadPct').value) || 0;
    const precioCalculo = total * (1 + utilidad / 100);

    document.getElementById('summaryEquipment').textContent = '$' + eq.toFixed(2);
    document.getElementById('summaryLabor').textContent = '$' + lb.toFixed(2);
    document.getElementById('summaryMaterials').textContent = '$' + mt.toFixed(2);
    document.getElementById('summaryTransport').textContent = '$' + tr.toFixed(2);
    document.getElementById('summaryTotal').textContent = '$' + total.toFixed(2);
    document.getElementById('summaryPrecioCalculo').textContent = '$' + precioCalculo.toFixed(2);

    // Sugerir precio ofertado = precio de cálculo redondeado
    const precioOfertadoInput = document.getElementById('precioOfertado');
    if (!precioOfertadoInput.dataset.manuallySet) {
        precioOfertadoInput.value = precioCalculo.toFixed(2);
    }
}

document.getElementById('utilidadPct').addEventListener('input', calculateTotals);
document.getElementById('precioOfertado').addEventListener('input', function() {
    this.dataset.manuallySet = '1';
});

// Agregar al menos una fila inicial en cada sección
addEquipmentRow();
addLaborRow();
addMaterialRow();
addTransportRow();

// Move floating submit container to body to avoid stacking-context overlay issues
document.addEventListener('DOMContentLoaded', function() {
    try {
        const el = document.querySelector('.apu-submit-floating');
        if (el && el.parentElement && el.parentElement.tagName.toLowerCase() !== 'body') {
            document.body.appendChild(el);
        }
    } catch (e) {
        console.error('move submit to body failed', e);
    }
});

// Disable pointer-events on elements that overlap the floating submit area on mobile
(function() {
    let disabled = [];
    function clearDisabled() {
        disabled.forEach(el => {
            try { el.style.pointerEvents = el.dataset._oldPointer || ''; delete el.dataset._oldPointer; } catch(e){}
        });
        disabled = [];
    }
    function disableOverlapping() {
        clearDisabled();
        if (window.innerWidth > 768) return;
        const btn = document.querySelector('.apu-submit-floating');
        if (!btn) return;
        const rect = btn.getBoundingClientRect();
        const cols = 3, rows = 2;
        const seen = new Set();
        for (let i=0;i<cols;i++){
            for (let j=0;j<rows;j++){
                const px = Math.round(rect.left + (i+0.5)*(rect.width/cols));
                const py = Math.round(rect.top + (j+0.5)*(rect.height/rows));
                document.elementsFromPoint(px, py).forEach(el => {
                    if (!el || el === btn) return;
                    if (seen.has(el)) return; seen.add(el);
                    try {
                        const cs = window.getComputedStyle(el);
                        if (cs.pointerEvents !== 'none') {
                            el.dataset._oldPointer = el.style.pointerEvents || '';
                            el.style.pointerEvents = 'none';
                            disabled.push(el);
                        }
                    } catch(e){}
                });
            }
        }
    }
    // Expose to window so event handlers can call it synchronously before the click
    window._apuClearDisabled = clearDisabled;
    window._apuDisableOverlapping = disableOverlapping;
    window.addEventListener('resize', disableOverlapping);
    document.addEventListener('DOMContentLoaded', function(){ setTimeout(disableOverlapping, 50); });
    // Run repeatedly for a short period on mobile to catch late-added elements
    document.addEventListener('DOMContentLoaded', function(){
        if (window.innerWidth > 768) return;
        let runs = 0;
        const tid = setInterval(function(){
            try { disableOverlapping(); } catch(e){}
            runs++;
            if (runs > 25) clearInterval(tid);
        }, 200);
        setTimeout(function(){ try{ clearInterval(tid); }catch(e){} }, 6000);
    });
    // Attach immediate handlers to the floating submit button so pointer-events are cleared right before interaction
    document.addEventListener('DOMContentLoaded', function(){
        const btn = document.querySelector('.apu-submit-floating');
        if (!btn) return;
        btn.addEventListener('pointerdown', function(){ try { window._apuDisableOverlapping(); } catch(e){} });
        btn.addEventListener('touchstart', function(){ try { window._apuDisableOverlapping(); } catch(e){} });
        btn.addEventListener('pointerup', function(){ setTimeout(window._apuClearDisabled, 300); });
        btn.addEventListener('touchend', function(){ setTimeout(window._apuClearDisabled, 300); });
    });
})();

    // Add a body class on mobile to hide interfering headers/buttons while floating submit is visible
    (function(){
        function updateBodyClass() {
            if (window.innerWidth <= 768) document.body.classList.add('apu-floating-active');
            else document.body.classList.remove('apu-floating-active');
        }
        window.addEventListener('resize', updateBodyClass);
        document.addEventListener('DOMContentLoaded', function(){ updateBodyClass(); });
    })();
</script>

    <style>
    /* Mobile: hide card headers and inline add-row buttons that intercepted clicks in tests */
    @media (max-width: 768px) {
        body.apu-floating-active .card-header { display: none !important; }
        body.apu-floating-active .btn.btn-light.float-end { display: none !important; }
    }
    </style>

    <style>
    /* Ensure floating submit is fixed and on top of everything */
    .apu-submit-floating {
        position: fixed !important;
        bottom: 16px !important;
        right: 16px !important;
        z-index: 2147483647 !important;
        pointer-events: auto !important;
    }
    </style>
    </style>
{% endblock %}
