{% extends 'base.html.twig' %}

{% block title %}{{ 'apu.title'|trans }}{% endblock %}

{% block body %}
{% import 'partials/_button.html.twig' as btn %}
{% import 'partials/_pagination.html.twig' as pager %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-calculator"></i> {{ 'apu.header'|trans }}</h1>
        <div class="d-flex gap-2">
            {{ btn.button('apu.new_apu'|trans, 'primary', 'bi-plus-circle', {'href': path('app_apu_create'), 'class':'btn-gradient'}) }}
            {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_dashboard')}) }}
        </div>
    </div>

    {% include 'partials/_flashes.html.twig' %}

    {% if apu_items|length > 0 %}
        <div class="card">
            <div class="card-body">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>{{ 'apu.column_description'|trans }}</th>
                            <th>{{ 'apu.column_unit'|trans }}</th>
                            <th>{{ 'apu.column_khu'|trans }}</th>
                            <th>{{ 'apu.column_rend'|trans }}</th>
                            <th class="text-end">{{ 'apu.column_total_cost'|trans }}</th>
                            <th>{{ 'apu.column_date'|trans }}</th>
                            <th class="text-center">{{ 'apu.actions'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in apu_items %}
                            <tr>
                                <td>{{ item.description }}</td>
                                <td><span class="badge bg-secondary">{{ item.unit }}</span></td>
                                <td>{{ item.khu|number_format(4) }}</td>
                                <td>{{ item.rendimientoUh|number_format(4) }}</td>
                                <td class="text-end">
                                    <strong>${{ item.totalCost|number_format(2) }}</strong>
                                </td>
                                <td>{{ item.createdAt|date('d/m/Y') }}</td>
                                <td class="text-center">
                                    {{ btn.button('', 'outline-primary', 'bi-pencil', {'href': path('app_apu_edit', {id: item.id}), 'title': 'apu.edit'|trans, 'class':'btn-sm'}) }}
                                    {{ btn.button('', 'outline-success', 'bi-file-earmark-excel', {'href': path('app_apu_export_excel', {id: item.id}), 'title': 'apu.export_excel'|trans, 'class':'btn-sm'}) }}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% if totalPages > 1 %}
            <div class="card-footer d-flex justify-content-between align-items-center">
                {{ pager.info(currentPage, totalPages) }}
                {{ pager.render(currentPage, totalPages, 'app_apu_index') }}
            </div>
            {% endif %}
        </div>
    {% else %}
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> {{ 'apu.no_apus'|trans }}
            <a href="{{ path('app_apu_create') }}" class="alert-link">{{ 'apu.create_first'|trans }}</a>
        </div>
    {% endif %}
</div>
{% endblock %}
