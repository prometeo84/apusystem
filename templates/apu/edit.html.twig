{% extends 'base.html.twig' %}

{% block title %}{{ 'apu.edit.title'|trans }} - APU System{% endblock %}

{% block body %}
<div class="container mt-4">
    <h1><i class="bi bi-pencil"></i> {{ 'apu.edit.title'|trans }}</h1>

    <form method="POST" id="apuForm">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                {{ 'apu.main_data'|trans }}
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label">{{ 'apu.label.item_description'|trans }}</label>
                            <input type="text" class="form-control" name="description"
                                   value="{{ apu_item.description }}" required>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label">{{ 'apu.unit'|trans }}</label>
                            <select class="form-select" name="unit" required>
                                <option value="">{{ 'common.select'|trans }}</option>
                                <option value="m²" {% if apu_item.unit == 'm²' %}selected{% endif %}>{{ 'units.m2'|trans }}</option>
                                <option value="m³" {% if apu_item.unit == 'm³' %}selected{% endif %}>{{ 'units.m3'|trans }}</option>
                                <option value="m" {% if apu_item.unit == 'm' %}selected{% endif %}>{{ 'units.m'|trans }}</option>
                                <option value="kg" {% if apu_item.unit == 'kg' %}selected{% endif %}>{{ 'units.kg'|trans }}</option>
                                <option value="u" {% if apu_item.unit == 'u' %}selected{% endif %}>{{ 'units.u'|trans }}</option>
                                <option value="GLB" {% if apu_item.unit == 'GLB' %}selected{% endif %}>{{ 'units.GLB'|trans }}</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">K(H/U)</label>
                            <input type="number" step="0.0001" class="form-control" name="khu"
                                   value="{{ apu_item.khu }}" required>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label">Rend. u/h</label>
                            <input type="number" step="0.0001" class="form-control" name="rendimiento_uh"
                                   value="{{ apu_item.rendimientoUh }}" required>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Secciones Equipo, Labor, Materials, Transport igual que create.html.twig -->
        <!-- Por brevedad, usar mismo código JavaScript -->

        <div class="text-end">
            {% import 'partials/_button.html.twig' as btn %}
            {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_apu_index')}) }}
            {{ btn.button('apu.update'|trans, 'primary', 'bi-save', {'type':'submit'}) }}
        </div>
    </form>
</div>
{% endblock %}
