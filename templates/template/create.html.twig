{% extends 'base.html.twig' %}
{% block title %}{{ 'plantilla.new'|trans }} - {{ project.name }}{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container mt-4" style="max-width:650px">
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_project_show', {id: project.id}) }}">{{ project.name }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_template_index', {projectId: project.id}) }}">{{ 'plantilla.title'|trans }}</a></li>
            <li class="breadcrumb-item active">{{ 'plantilla.new'|trans }}</li>
        </ol>
    </nav>
    <div class="card">
        <div class="card-header bg-primary text-white"><i class="bi bi-plus-circle"></i> {{ 'plantilla.new'|trans }}</div>
        <div class="card-body">
            {% include 'partials/_flashes.html.twig' %}
            <form method="POST" action="{{ path('app_template_create', {projectId: project.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('plantilla_create_' ~ project.id) }}">
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'plantilla.col_name'|trans }} <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" name="nombre" maxlength="255" required>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'common.description'|trans }}</label>
                    <textarea class="form-control" name="descripcion" rows="2"></textarea>
                </div>
                <div class="text-end">
                    {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_template_index', {projectId: project.id})}) }}
                    &nbsp;
                    {{ btn.button('plantilla.save'|trans, 'primary', 'bi-save', {'type':'submit'}) }}
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
