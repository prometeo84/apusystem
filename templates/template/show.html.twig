{% extends 'base.html.twig' %}
{% block title %}{{ template.name }} - {{ project.name }}{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container-fluid mt-4">
    {# Breadcrumb + cabecera #}
    <nav aria-label="breadcrumb" class="mb-2">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_project_index') }}">{{ 'project.title'|trans }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_project_show', {id: project.id}) }}">{{ project.name }}</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_template_index', {projectId: project.id}) }}">{{ 'template.title'|trans }}</a></li>
            <li class="breadcrumb-item active">{{ template.name }}</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-start mb-3">
        <div>
            <h1 class="mb-0"><i class="bi bi-layout-text-sidebar"></i> {{ template.name }}</h1>
            {% if template.description %}<p class="text-muted mb-0">{{ template.description }}</p>{% endif %}
        </div>
        <div class="d-flex gap-2">
            {{ btn.button('template.edit'|trans, 'outline-primary', 'bi-pencil', {'href': path('app_template_edit', {projectId: project.id, id: template.id}), 'class':'btn-sm'}) }}
            {# Duplicar #}
                <form method="POST" action="{{ path('app_template_duplicate', {projectId: project.id, id: template.id}) }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('plantilla_dup_' ~ template.id) }}">
                {{ btn.button('template.duplicate'|trans, 'outline-secondary', 'bi-copy', {'type':'submit', 'class':'btn-sm'}) }}
            </form>
            {# Reporte #}
                    {{ btn.button('report.generate'|trans, 'success', 'bi-file-earmark-bar-graph', {'href': path('app_report_plantilla', {projectId: project.id, id: template.id}), 'class':'btn-sm'}) }}
                    {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_template_index', {projectId: project.id}), 'class':'btn-sm'}) }}
        </div>
    </div>

    {% include 'partials/_flashes.html.twig' %}

    {# ── Sección: APUs (solo APUs creados) ── #}
    {% set apus_list = template.items|filter(pr => pr.apuItem is not null) %}

    <div class="card mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <div>
                <i class="bi bi-calculator"></i> {{ 'plantilla.apus'|trans }} <span class="badge bg-white text-primary ms-1">{{ apus_list|length }}</span>
            </div>
            <div class="d-flex gap-2 align-items-center">
                {% if not is_granted('ROLE_ADMIN') %}
                    {{ btn.button('apu.create'|trans, 'outline-light', 'bi-plus-lg', {'href': path('app_apu_create_for_template', {templateId: template.id}), 'class':'btn-sm'}) }}
                {% endif %}
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                    <thead class="table">
                        <tr>
                            <th style="width:3.5rem">#</th>
                            <th>{{ 'apu.column_description'|trans }}</th>
                            <th class="text-center">{{ 'common.actions'|trans }}</th>
                        </tr>
                    </thead>
                <tbody>
                            {% for pr in apus_list %}
                            <tr>
                                <td class="text-muted" style="width:3.5rem">{{ loop.index }}</td>
                                <td><strong>{{ pr.apuItem.description ?: pr.item.name }}</strong></td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">
                                        {% if not is_granted('ROLE_ADMIN') %}
                                            {{ btn.button('', 'outline-primary', 'bi-pencil', {'href': path('app_apu_edit', {id: pr.apuItem.id}), 'class':'btn-sm', 'title': 'apu.edit'|trans}) }}
                                        {% endif %}
                                        <form method="POST" action="{{ path('app_template_unlink_apu', {projectId: project.id, id: template.id, prId: pr.id}) }}" class="d-inline"
                                              onsubmit="return confirm('{{ 'plantilla.confirm_remove_rubro'|trans }}')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('unlink_apu_' ~ pr.id) }}">
                                            {{ btn.button('', 'outline-danger', 'bi-trash', {'type':'submit', 'class':'btn-sm', 'title': 'Remove APU'}) }}
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                </tbody>
                <tfoot>
                    <tr class="table-primary fw-bold">
                        <td></td>
                        <td></td>
                        <td class="text-center">{{ 'plantilla.total_presupuesto'|trans }}: <span class="fs-5">${{ template.totalBudget|number_format(2, '.', ',') }}</span></td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

    {# Add/remove UI removed as requested #}
</div>
{% endblock %}
