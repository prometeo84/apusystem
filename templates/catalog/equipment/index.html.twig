{% extends 'base.html.twig' %}
{% block title %}{{ 'equipment'|trans }} - Catalog{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container-fluid mt-4">
    {% include 'partials/_flashes.html.twig' %}
    <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><i class="bi bi-hdd"></i> {{ 'equipment'|trans }}</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <div class="d-flex align-items-center gap-2">
                {{ btn.button('common.add_equipment'|trans, 'primary', 'bi-plus-circle', {'href': path('catalog_equipment_create')}) }}
                {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_dashboard')}) }}
            </div>
        {% endif %}
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>{{ 'common.code'|trans }}</th>
                        <th>{{ 'common.name'|trans }}</th>
                        <th class="text-center">Activo</th>
                        <th class="text-center">{{ 'common.actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for it in items %}
                    <tr>
                        <td><code>{{ it.code }}</code></td>
                        <td>{{ it.name }}</td>
                        <td class="text-center">
                            {% if it.active %}
                                <span class="badge bg-success">Activo</span>
                            {% else %}
                                <span class="badge bg-secondary">Inactivo</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            {% if is_granted('ROLE_ADMIN') %}
                                {{ btn.button('', 'secondary', 'bi-pencil', {'href': path('catalog_equipment_edit', {id: it.id}), 'class':'btn-sm'}) }}
                                {{ btn.button('', 'danger', 'bi-trash', {'href': path('catalog_equipment_delete_confirm', {id: it.id}), 'class':'btn-sm'}) }}
                            {% else %}
                                --
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="4" class="text-center text-muted">{{ 'common.no_records'|trans|default('No records') }}</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
