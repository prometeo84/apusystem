{% extends 'base.html.twig' %}
{% block title %}Equipos - Catalog{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-hdd"></i> Equipos</h1>
        {% if is_granted('ROLE_ADMIN') %}
            <div class="d-flex align-items-center gap-2">
                {{ btn.button('Nuevo Equipo', 'primary', 'bi-plus-circle', {'href': path('catalog_equipment_create')}) }}
                {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('app_dashboard')}) }}
            </div>
        {% endif %}
    </div>

    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Código</th>
                        <th>Nombre</th>
                        <th>Unidad</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    {% for it in items %}
                    <tr>
                        <td><code>{{ it.code }}</code></td>
                        <td>{{ it.name }}</td>
                        <td>{{ it.unit }}</td>
                        <td class="text-center">
                            {% if is_granted('ROLE_ADMIN') %}
                                {{ btn.button('', 'secondary', 'bi-pencil', {'href': path('catalog_equipment_edit', {id: it.id}), 'class':'btn-sm'}) }}
                                {{ btn.button('', 'danger', 'bi-trash', {'href': path('catalog_equipment_delete_confirm', {id: it.id}), 'class':'btn-sm'}) }}
                            {% else %}
                                --
                            {% endif %}
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="4" class="text-center text-muted">No hay equipos</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
