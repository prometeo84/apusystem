{% extends 'base.html.twig' %}
{% block title %}Editar Equipo{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container-fluid mt-4">
    <div class="mb-3">
        <h1><i class="bi bi-hdd"></i> Editar Equipo</h1>
    </div>
    <form method="POST" action="{{ path('catalog_equipment_edit', {id: item.id}) }}">
        <input type="hidden" name="_token" value="{{ csrf_token('equipment_edit_' ~ item.id) }}">
        <div class="mb-3">
            <label class="form-label">Código</label>
            <input class="form-control" name="code" value="{{ item.code }}" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Nombre</label>
            <input class="form-control" name="name" value="{{ item.name }}" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Unidad</label>
            <input class="form-control" name="unit" value="{{ item.unit }}">
        </div>
        {{ btn.button('Guardar', 'primary', 'bi-save', {'type':'submit'}) }}
        {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('catalog_equipment_index')}) }}
    </form>
</div>
{% endblock %}
