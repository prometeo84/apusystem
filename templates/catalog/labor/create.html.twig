{% extends 'base.html.twig' %}
{% block title %}{{ 'apu.labor_new'|trans }}{% endblock %}
{% block body %}
{% import 'partials/_button.html.twig' as btn %}
<div class="container-fluid mt-4">
    {% include 'partials/_flashes.html.twig' %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0"><i class="bi bi-people"></i> {{ 'apu.labor_new'|trans }}</h1>
        {{ btn.button('buttons.back'|trans, 'secondary', 'bi-arrow-left', {'href': path('catalog_labor_index')}) }}
    </div>
    <div class="card mx-auto" style="max-width:600px;">
        <div class="card-body">
            <form method="POST" action="{{ path('catalog_labor_create') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('labor_create') }}">
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'common.code'|trans }} <span class="text-danger">*</span></label>
                    <input class="form-control" name="code" required autofocus placeholder="Ej: MO-001">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'common.description'|trans }} <span class="text-danger">*</span></label>
                    <input class="form-control" name="description" required placeholder="Ej: Maestro de obra">
                </div>
                <div class="mb-4">
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" name="active" id="active" value="1" checked>
                        <label class="form-check-label" for="active">{{ 'common.active'|trans }}</label>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">{{ 'items.visibility.label'|trans }}</label>
                    <select class="form-select" name="visibility" id="visibility-select">
                        <option value="tenant">{{ 'items.visibility.tenant'|trans }}</option>
                        <option value="project">{{ 'items.visibility.project'|trans }}</option>
                    </select>
                </div>
                <div class="mb-3" id="project-select-group" style="display:none;">
                    <label class="form-label fw-semibold">{{ 'common.project_optional'|trans }}</label>
                    <select class="form-select" name="project_id">
                        <option value="">{{ 'common.select'|trans }}</option>
                        {% for p in projects %}
                            <option value="{{ p.id }}">{{ p.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                {{ btn.button('buttons.save'|trans, 'primary', 'bi-save', {'type':'submit'}) }}
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function(){
            const vis = document.getElementById('visibility-select');
            const group = document.getElementById('project-select-group');
            if (!vis || !group) return;
            vis.addEventListener('change', function(){
                group.style.display = vis.value === 'project' ? 'block' : 'none';
            });
        })();
    </script>
{% endblock %}
