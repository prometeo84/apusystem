{#
  Generic modal macro.

  Usage:
    {% import 'partials/_modal.html.twig' as modals %}

    {{ modals.trigger('myModal', 'Open', 'primary', 'bi-eye') }}

    {% call(slot) modals.dialog('myModal', 'Modal Title', 'lg') %}
        {% if slot == 'body' %}
            <p>Body content here</p>
        {% elseif slot == 'footer' %}
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        {% endif %}
    {% endcall %}

  For simple inline modals just use open_modal and close_modal helpers:
    {% import 'partials/_modal.html.twig' as modals %}
    {{ modals.open('my-modal-id', 'Modal Title', 'lg') }}
        <p>Content here</p>
    {{ modals.footer() }}
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
    {{ modals.close() }}
#}

{# Render a button that opens a modal #}
{% macro trigger(targetId, label, variant='primary', icon=null, extraClass='') %}
    {% import 'partials/_button.html.twig' as btn %}
    {{ btn.button(label, variant, icon, {
        'data-bs-toggle': 'modal',
        'data-bs-target': '#' ~ targetId,
        'class': extraClass
    }) }}
{% endmacro %}

{# Open a modal (block-style) - use with open/footer/close pattern #}
{% macro open(id, title, size='', scrollable=false) %}
<div class="modal fade" id="{{ id }}" tabindex="-1" aria-labelledby="{{ id }}Label" aria-hidden="true">
    <div class="modal-dialog{% if size %} modal-{{ size }}{% endif %}{% if scrollable %} modal-dialog-scrollable{% endif %}">
        <div class="modal-content">
            {% if title %}
            <div class="modal-header">
                <h5 class="modal-title" id="{{ id }}Label">{{ title }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            {% endif %}
            <div class="modal-body">
{% endmacro %}

{% macro footer() %}
            </div>
            <div class="modal-footer">
{% endmacro %}

{% macro close() %}
            </div>
        </div>
    </div>
</div>
{% endmacro %}
