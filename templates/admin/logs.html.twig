{% extends 'base.html.twig' %}

{% block title %}{{ 'system_errors.title'|trans }} - APU System{% endblock %}

{% block body %}
{% import 'partials/_button.html.twig' as btn %}
{% import 'partials/_pagination.html.twig' as pager %}
<div class="d-flex">
    {% include 'partials/_sidebar.html.twig' %}

    <div class="flex-grow-1">
        {% include 'partials/_navbar.html.twig' with {'title': 'nav.security_logs'|trans} %}

        <div class="container-fluid p-4 content-wrapper">
            <div class="card">
                <div class="card-header">
                    <div class="row align-items-center">
                        <div class="col">
                            <h5 class="mb-0"><i class="bi bi-file-text"></i> {{ 'security.events'|trans }}</h5>
                        </div>
                        <div class="col-auto">
                            <div class="btn-group">
                                {{ btn.button('system.all'|trans, 'outline-secondary', null, {'class':'btn-sm' ~ (activeSeverity == '' ? ' active' : ''),'href':path('app_admin_logs')}) }}
                                {{ btn.button('system.info'|trans, 'outline-success', null, {'class':'btn-sm' ~ (activeSeverity == 'INFO' ? ' active' : ''),'href':path('app_admin_logs', {'severity':'INFO'})}) }}
                                {{ btn.button('system.warnings'|trans, 'outline-warning', null, {'class':'btn-sm' ~ (activeSeverity == 'WARNING' ? ' active' : ''),'href':path('app_admin_logs', {'severity':'WARNING'})}) }}
                                {{ btn.button('system.critical'|trans, 'outline-danger', null, {'class':'btn-sm' ~ (activeSeverity == 'CRITICAL' ? ' active' : ''),'href':path('app_admin_logs', {'severity':'CRITICAL'})}) }}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="logsTable">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 150px;">{{ 'system.datetime'|trans }}</th>
                                    <th>{{ 'common.user'|trans }}</th>
                                    <th>{{ 'security.event'|trans }}</th>
                                    <th>IP</th>
                                    <th>{{ 'common.browser'|trans }}</th>
                                    <th style="width: 100px;">{{ 'security.severity'|trans }}</th>
                                    <th style="width: 60px;">{{ 'admin.logs.details_label'|trans }}</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for event in securityEvents %}
                                    <tr data-severity="{{ event.severity }}">
                                        <td>
                                            <small>{{ event.createdAt|date('d/m/Y') }}</small><br>
                                            <small class="text-muted">{{ event.createdAt|date('H:i:s') }}</small>
                                        </td>
                                        <td>
                                            {% if event.user %}
                                                <strong>{{ event.user.firstName }} {{ event.user.lastName }}</strong><br>
                                                <small class="text-muted">{{ event.user.email }}</small>
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">
                                                {{ event.eventType|replace({'_': ' '})|title }}
                                            </span>
                                        </td>
                                        <td>
                                            <code>{{ event.ipAddress }}</code>
                                        </td>
                                        <td>
                                            <small class="text-muted">
                                                {{ event.userAgent|slice(0, 40) }}...
                                            </small>
                                        </td>
                                        <td>
                                            <span class="badge bg-{{ event.severity == 'CRITICAL' ? 'danger' : (event.severity == 'WARNING' ? 'warning' : 'info') }}">
                                                {{ event.severity }}
                                            </span>
                                        </td>
                                        <td>
                                            {% if event.eventData %}
                                                {{ btn.button('', 'outline-secondary', 'bi-eye', {'class':'btn-sm','type':'button','data-bs-toggle':'modal','data-bs-target':'#detailsModal' ~ event.id}) }}
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">
                            {{ 'system.showing_events'|trans({'%count%': securityEvents|length}) }}
                            {% if totalPages > 1 %}
                                &mdash; {{ pager.info(currentPage, totalPages) }}
                            {% endif %}
                        </small>
                        <span id="logsPagination">
                            {{ pager.render(currentPage, totalPages, 'app_admin_logs', activeSeverity != '' ? {'severity': activeSeverity} : {}) }}
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modales de detalles -->
{% for event in securityEvents %}
    {% if event.eventData %}
        <div class="modal fade" id="detailsModal{{ event.id }}" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">{{ 'admin.logs.details_title'|trans }}</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <dl class="row">
                            <dt class="col-sm-3">{{ 'system.datetime'|trans }}:</dt>
                            <dd class="col-sm-9">{{ event.createdAt|date('d/m/Y H:i:s') }}</dd>

                            <dt class="col-sm-3">{{ 'common.user'|trans }}:</dt>
                            <dd class="col-sm-9">
                                {% if event.user %}
                                    {{ event.user.email }}
                                {% else %}
                                    No disponible
                                {% endif %}
                            </dd>

                            <dt class="col-sm-3">{{ 'security.event'|trans }}:</dt>
                            <dd class="col-sm-9">{{ event.eventType|replace({'_': ' '})|title }}</dd>

                            <dt class="col-sm-3">IP:</dt>
                            <dd class="col-sm-9"><code>{{ event.ipAddress }}</code></dd>

                            <dt class="col-sm-3">{{ 'common.browser'|trans }}:</dt>
                            <dd class="col-sm-9"><small>{{ event.userAgent }}</small></dd>

                            <dt class="col-sm-3">{{ 'security.severity'|trans }}:</dt>
                            <dd class="col-sm-9">
                                <span class="badge bg-{{ event.severity == 'CRITICAL' ? 'danger' : (event.severity == 'WARNING' ? 'warning' : 'info') }}">
                                    {{ event.severity }}
                                </span>
                            </dd>

                            <dt class="col-sm-3">{{ 'admin.logs.details_label'|trans }}:</dt>
                            <dd class="col-sm-9">
                                <pre class="bg-light p-2 rounded"><code>{{ event.eventData|json_encode(constant('JSON_PRETTY_PRINT')) }}</code></pre>
                            </dd>
                        </dl>
                    </div>
                    <div class="modal-footer">
                        {{ btn.button('buttons.close'|trans, 'secondary', null, {'type':'button','data-bs-dismiss':'modal'}) }}
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endfor %}

{% endblock %}
