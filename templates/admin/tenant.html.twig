{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.tenant.title'|trans }} - APU System{% endblock %}

{% block body %}
<div class="d-flex">
    {% include 'partials/_sidebar.html.twig' %}

    <div class="flex-grow-1">
        {% include 'partials/_navbar.html.twig' with {'title': ('admin.tenant.title'|trans)} %}

        <div class="container-fluid p-4 content-wrapper">
            {% if is_granted('ROLE_SUPER_ADMIN') and allTenants is defined %}
                        <form method="get" class="mb-3">
                    <div class="d-flex align-items-center gap-2">
                        <label class="form-label mb-0">{{ 'admin.select_company_label'|trans }}</label>
                        <select name="tenant_id" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                            {% for t in allTenants %}
                                    <option value="{{ t.id }}" {{ t.id == tenant.id ? 'selected' : '' }}>
                                    {{ t.name }} - {{ t.isActive ? ('system.status_active'|trans) : ('system.status_inactive'|trans) }}
                                </option>
                            {% endfor %}
                        </select>
                    </div>
                </form>
            {% endif %}
            {% for message in app.flashes('success') %}
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill"></i> {{ message|trans }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}

            <div class="row">
                <div class="col-md-8">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-building"></i> {{ 'admin.tenant.info_company'|trans }}</h5>
                        </div>
                        <div class="card-body">
                            <form method="post" action="{{ path('app_admin_tenant') }}">
                                <input type="hidden" name="tenant_id" value="{{ tenant.id }}">
                                <div class="mb-3">
                                    <label class="form-label">{{ 'system.commercial_name'|trans }}</label>
                                    <input type="text" name="name" class="form-control"
                                           value="{{ tenant.name }}" required>
                                </div>

                                {# Campos adicionales (requieren migración de BD)
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">NIT / RUT</label>
                                        <input type="text" name="tax_id" class="form-control" value="">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Email Corporativo</label>
                                        <input type="email" name="email" class="form-control" value="">
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">{{ 'admin.phone'|trans }}</label>
                                        <input type="tel" name="phone" class="form-control" value="">
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Sitio Web</label>
                                        <input type="url" name="website" class="form-control" value="" placeholder="https://">
                                    </div>
                                </div>
                                        {% import 'partials/_button.html.twig' as btn %}
                                        {{ btn.button('admin.save_settings'|trans, 'primary', 'bi-save', {'type':'submit'}) }}
                                    <textarea name="address" class="form-control" rows="2"></textarea>
                                </div>

                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label">Ciudad</label>
                                        <input type="text" name="city" class="form-control" value="">
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label">{{ 'admin.state_region'|trans }}</label>
                                        <input type="text" name="state" class="form-control" value="">
                                    </div>
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label">{{ 'admin.country'|trans }}</label>
                                        <input type="text" name="country" class="form-control" value="">
                                    </div>
                                </div>
                                #}

                                {{ btn.button('profile.save'|trans, 'primary', 'bi-bi-save', {'type':'submit'}) }}
                            </form>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-gear"></i> {{ 'admin.system_settings'|trans }}</h5>
                        </div>
                        <div class="card-body">
                            <form method="post" action="{{ path('app_admin_tenant') }}">
                                <input type="hidden" name="tenant_id" value="{{ tenant.id }}">
                                <input type="hidden" name="settings_form" value="1">

                                <div class="mb-3">
                                    <label class="form-label">{{ 'admin.timezone_label'|trans }}</label>
                                    <select name="timezone" class="form-select">
                                        <option value="America/Bogota" {{ tenant.settings.timezone|default('America/Bogota') == 'America/Bogota' ? 'selected' : '' }}>
                                            América/Bogotá (GMT-5)
                                        </option>
                                        <option value="America/Mexico_City" {{ tenant.settings.timezone|default('') == 'America/Mexico_City' ? 'selected' : '' }}>
                                            América/Ciudad de México (GMT-6)
                                        </option>
                                        <option value="America/Lima" {{ tenant.settings.timezone|default('') == 'America/Lima' ? 'selected' : '' }}>
                                            América/Lima (GMT-5)
                                        </option>
                                        <option value="America/Santiago" {{ tenant.settings.timezone|default('') == 'America/Santiago' ? 'selected' : '' }}>
                                            América/Santiago (GMT-4/GMT-3)
                                        </option>
                                    </select>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">{{ 'admin.currency_label'|trans }}</label>
                                    <select name="currency" class="form-select">
                                        <option value="COP" {{ tenant.settings.currency|default('COP') == 'COP' ? 'selected' : '' }}>
                                            {{ 'system.currency.COP'|trans }}
                                        </option>
                                        <option value="USD" {{ tenant.settings.currency|default('') == 'USD' ? 'selected' : '' }}>
                                            {{ 'system.currency.USD'|trans }}
                                        </option>
                                        <option value="MXN" {{ tenant.settings.currency|default('') == 'MXN' ? 'selected' : '' }}>
                                            {{ 'system.currency.MXN'|trans }}
                                        </option>
                                        <option value="PEN" {{ tenant.settings.currency|default('') == 'PEN' ? 'selected' : '' }}>
                                            {{ 'system.currency.PEN'|trans }}
                                        </option>
                                        <option value="CLP" {{ tenant.settings.currency|default('') == 'CLP' ? 'selected' : '' }}>
                                            {{ 'system.currency.CLP'|trans }}
                                        </option>
                                    </select>
                                </div>

                                <div class="form-check mb-3">
                                    <input type="checkbox" name="require_2fa" class="form-check-input" id="require2FA"
                                           {{ tenant.settings.require2fa|default(false) ? 'checked' : '' }}>
                                    <label class="form-check-label" for="require2FA">
                                        {{ 'admin.require_2fa_label'|trans }}
                                    </label>
                                </div>

                                <div class="form-check mb-3">
                                    <input type="checkbox" name="enable_email_notifications" class="form-check-input" id="emailNotifications"
                                           {{ tenant.settings.emailNotifications|default(true) ? 'checked' : '' }}>
                                    <label class="form-check-label" for="emailNotifications">
                                        {{ 'admin.enable_email_notifications'|trans }}
                                    </label>
                                </div>

                                {{ btn.button('admin.save_settings'|trans, 'primary', 'bi-bi-save', {'type':'submit'}) }}
                            </form>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-credit-card"></i> {{ 'admin.current_plan'|trans }}</h5>
                        </div>
                        <div class="card-body text-center">
                            <h2 class="text-primary">{{ tenant.plan|upper }}</h2>
                            <p class="text-muted">
                                {% if tenant.plan == 'trial' %}
                                    {{ 'system.plan_trial'|trans }}
                                {% elseif tenant.plan == 'basic' %}
                                    {{ 'system.plan_basic'|trans }}
                                {% elseif tenant.plan == 'professional' %}
                                    {{ 'system.plan_professional'|trans }}
                                {% elseif tenant.plan == 'enterprise' %}
                                    {{ 'system.plan_enterprise'|trans }}
                                {% endif %}
                            </p>

                            <div class="alert alert-{{ tenant.isActive ? 'success' : 'danger' }}">
                                {{ 'system.status'|trans }}: <strong>{{ tenant.isActive ? ('system.status_active'|trans) : ('system.status_inactive'|trans) }}</strong>
                            </div>

                            <hr>

                            <dl class="row text-start">
                                <dt class="col-6">{{ 'admin.users_label'|trans }}:</dt>
                                <dd class="col-6">{{ tenant.maxUsers }} {{ 'admin.max_label'|trans }}</dd>

                                <dt class="col-6">{{ 'admin.projects_label'|trans }}:</dt>
                                <dd class="col-6">{{ tenant.maxProjects }}</dd>
                            </dl>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-header">
                            <h5 class="mb-0"><i class="bi bi-info-circle"></i> {{ 'admin.system_information'|trans }}</h5>
                        </div>
                        <div class="card-body">
                            <dl class="mb-0">
                                <dt>{{ 'common.created'|trans }}:</dt>
                                <dd>{{ tenant.createdAt|date('d/m/Y') }}</dd>

                                <dt>{{ 'system.tenant_id_label'|trans }}:</dt>
                                <dd><code>{{ tenant.id }}</code></dd>

                                <dt>{{ 'system.subdomain'|trans }}:</dt>
                                <dd>{{ tenant.slug }}</dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
