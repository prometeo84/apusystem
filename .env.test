# .env.test — Variables de entorno para el entorno de pruebas (CI y tests unitarios)
# Este archivo es seguro para commitear: contiene valores de placeholder sin datos reales.
# Es cargado automáticamente por Symfony cuando APP_ENV=test.

APP_ENV=test
APP_DEBUG=0
APP_SECRET=ci_test_secret_not_used_in_production_32bytes!!

DATABASE_URL=sqlite:///%kernel.cache_dir%/test.db

MAILER_DSN=null://null
MAILER_FROM_ADDRESS=test@ci.example.com
MAILER_FROM_NAME="CI Tests"

DEFAULT_URI=http://localhost
SESSION_LIFETIME=3600
LOCK_DSN=flock

JWT_SECRET_KEY=
JWT_PUBLIC_KEY=
JWT_PASSPHRASE=

CRON_JOB_API_KEY=ci_not_used
VAR_DUMPER_SERVER=127.0.0.1:9912

SYMFONY_DECRYPTION_SECRET=
DEFAULT_TIMEZONE=UTC
ENCRYPTION_KEY=ci_not_real_just_placeholder_key32
