# Environment variables template
# Copy this file to .env.dev for local development and set real values.

# Application
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_me_replace_with_strong_random

# Optional: Symfony secrets vault (base64 key)
SYMFONY_DECRYPTION_SECRET=

# Database
DATABASE_URL=mysql://db_user:db_pass@127.0.0.1:3306/db_name

# Mailer
MAILER_DSN=smtp://localhost:1025
MAILER_FROM_ADDRESS=noreply@example.com
MAILER_FROM_NAME="APU System"

# App / Router
DEFAULT_URI=http://localhost
SESSION_LIFETIME=3600
LOCK_DSN=flock

# JWT (if used)
JWT_SECRET_KEY=

# Misc / dev
CRON_JOB_API_KEY=
VAR_DUMPER_SERVER=127.0.0.1:9912
### APU System - plantilla de variables de entorno
# Copiar a .env.dev para desarrollo local y a .env.prod en producción
# No poner valores secretos en este archivo committeado; usar valores reales
# en .env.dev (local) y en el entorno del servidor (.env.prod o variables de entorno)

# Ambiente
APP_ENV=dev
APP_SECRET=REPLACE_ME_GENERATE_A_STRONG_SECRET

# Base de Datos
# Ej: DATABASE_URL="mysql://user:pass@127.0.0.1:3306/apu_system?serverVersion=8.0"
DATABASE_URL=REPLACE_ME

# Mailer
MAILER_DSN=REPLACE_ME
MAILER_FROM_ADDRESS=noreply@apusystem.com
MAILER_FROM_NAME=APU System

# JWT
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=REPLACE_ME

# Timezone
DEFAULT_TIMEZONE=America/Guayaquil

# Encriptación (si la usa la app)
ENCRYPTION_KEY=REPLACE_ME

# Rate limiting
RATE_LIMIT_ENABLED=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW=900
